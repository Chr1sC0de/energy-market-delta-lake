.*
__pycache__
node_modules/
dist/
!.envrc
!.vscode
!.ignore
!.git
!.dockerignore
!.pre-commit*
!.agents
!.agents/skills
!.agents/skills/ralph-loop
!.agents/skills/ralph-loop/SKILL.md
!.agents/skills/ralph-triage
!.agents/skills/ralph-triage/SKILL.md
!.gitkeep

# Gas market knowledge base generated text artifacts are intentionally reviewable.
!tools/gas-market-knowledge-base/.pre-commit-config.yaml
!tools/gas-market-knowledge-base/generated/
!tools/gas-market-knowledge-base/generated/bronze/
!tools/gas-market-knowledge-base/generated/silver/
!tools/gas-market-knowledge-base/generated/gold/
!tools/gas-market-knowledge-base/generated/**/.gitkeep
!tools/gas-market-knowledge-base/generated/**/*.json
!tools/gas-market-knowledge-base/generated/**/*.md
!tools/gas-market-knowledge-base/generated/**/*.txt
!tools/gas-market-knowledge-base/generated/**/*.yaml
!tools/gas-market-knowledge-base/generated/**/*.yml

# Raw PDF caches stay local to the Gas market knowledge base Subproject.
tools/gas-market-knowledge-base/.pdf-cache/
tools/gas-market-knowledge-base/cache/
tools/gas-market-knowledge-base/raw-pdfs/
tools/gas-market-knowledge-base/**/*.pdf

infrastructure/*-legacy
