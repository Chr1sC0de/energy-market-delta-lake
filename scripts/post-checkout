#!/bin/sh
# git post-checkout hook — managed by scripts/install-hooks.sh
#
# Automatically installs the prek pre-commit hook whenever a worktree is
# created (git worktree add) or checked out (git checkout).
#
# Arguments passed by git:
#   $1 - previous HEAD ref
#   $2 - new HEAD ref
#   $3 - flag: 1 = branch checkout, 0 = file checkout
#
# We only run on branch checkouts (including worktree add), not file checkouts.
[ "$3" = "0" ] && exit 0

if command -v prek > /dev/null 2>&1; then
    prek install --overwrite
else
    echo "post-checkout: prek not found on PATH — skipping hook install." >&2
    echo "  Run scripts/install-hooks.sh after installing prek." >&2
fi
