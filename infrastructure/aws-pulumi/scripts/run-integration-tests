#!/usr/bin/env bash
# Runs the guarded AWS Pulumi deployed-test command sequence.

set -euo pipefail

STACK="${PULUMI_STACK:-dev-ausenergymarket}"
AWS_REGION="${AWS_DEFAULT_REGION:-ap-southeast-2}"
RUN_UP=1
RUN_IDEMPOTENCY=0
HAS_AWS_CLI=0

reject_aws_endpoint_overrides() {
	local -a override_names=()
	local name

	for name in "${!AWS_ENDPOINT_URL@}"; do
		if [[ -n "${!name}" ]]; then
			override_names+=("$name")
		fi
	done

	if [[ "${#override_names[@]}" -eq 0 ]]; then
		return
	fi

	mapfile -t override_names < <(printf '%s\n' "${override_names[@]}" | sort)

	printf 'ERROR: deployed AWS workflow requires real AWS endpoints.\n' >&2
	printf 'ERROR: remove AWS endpoint override environment variables before retrying this Deployed test command.\n' >&2
	printf 'ERROR: rejected AWS endpoint override variables:\n' >&2
	printf '  %s\n' "${override_names[@]}" >&2
	exit 2
}

usage() {
	printf 'Usage: %s [--skip-up] [--with-idempotency] [--stack STACK]\n' "$0"
	printf '\n'
	printf 'Runs the deployed AWS test workflow for this Pulumi project.\n'
	printf '\n'
	printf 'Options:\n'
	printf '  --skip-up           Do not run pulumi up before tests.\n'
	printf '  --with-idempotency  Run pulumi preview --expect-no-changes after tests.\n'
	printf '  --stack STACK       Pulumi stack to target. Defaults to PULUMI_STACK or dev-ausenergymarket.\n'
	printf '  -h, --help          Show this help.\n'
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	--skip-up)
		RUN_UP=0
		shift
		;;
	--with-idempotency)
		RUN_IDEMPOTENCY=1
		shift
		;;
	--stack)
		if [[ $# -lt 2 ]]; then
			printf 'ERROR: --stack requires a value.\n' >&2
			exit 2
		fi
		STACK="$2"
		shift 2
		;;
	-h | --help)
		usage
		exit 0
		;;
	*)
		printf 'ERROR: unknown argument: %s\n' "$1" >&2
		usage >&2
		exit 2
		;;
	esac
done

reject_aws_endpoint_overrides

require_command() {
	if ! command -v "$1" >/dev/null 2>&1; then
		printf 'ERROR: required command not found: %s\n' "$1" >&2
		exit 127
	fi
}

require_command pulumi
require_command uv
require_command prek

export PULUMI_STACK="$STACK"
export AWS_DEFAULT_REGION="$AWS_REGION"
ENVIRONMENT_NAME="${ENVIRONMENT:-${PULUMI_STACK%%-*}}"
RESOURCE_NAME="${ENVIRONMENT_NAME}-energy-market"
CLUSTER_NAME="${RESOURCE_NAME}-dagster-cluster"

if command -v aws >/dev/null 2>&1; then
	HAS_AWS_CLI=1
	aws sts get-caller-identity >/dev/null
else
	printf 'WARN: aws CLI not found; Pulumi/pytest will still validate AWS credentials.\n' >&2
fi

printf 'Using Pulumi stack: %s\n' "$PULUMI_STACK"
printf 'Using AWS region: %s\n' "$AWS_DEFAULT_REGION"

pulumi stack select "$PULUMI_STACK"

printf '\n==> Running local Pulumi QA\n'
uv run pytest tests/unit tests/component -q
prek run -a

printf '\n==> Checking Cognito app client auth flow\n'
uv run python -m cognito_auth_flow_preflight \
	--region "$AWS_DEFAULT_REGION" \
	--resource-name "$RESOURCE_NAME"

if [[ "$RUN_UP" -eq 1 ]]; then
	printf '\n==> Applying Pulumi stack\n'
	pulumi up --yes --non-interactive --stack "$PULUMI_STACK"
else
	printf '\n==> Skipping pulumi up\n'
fi

mapfile -t SERVICES < <(
	RESOURCE_NAME="$RESOURCE_NAME" uv run python - <<'PY'
import os

from code_locations import required_ecs_service_names

resource_name = os.environ["RESOURCE_NAME"]
for service_name in required_ecs_service_names(resource_name):
    print(service_name)
PY
)

if [[ "$HAS_AWS_CLI" -eq 1 ]]; then
	printf '\n==> Waiting for ECS Fargate services to stabilize\n'
	aws ecs wait services-stable \
		--cluster "$CLUSTER_NAME" \
		--services "${SERVICES[@]}"

	ECS_STABILITY_HOLD_SECONDS="${ECS_STABILITY_HOLD_SECONDS:-75}"
	if [[ "$ECS_STABILITY_HOLD_SECONDS" != "0" ]]; then
		printf '\n==> Holding ECS stability for %ss\n' "$ECS_STABILITY_HOLD_SECONDS"
		sleep "$ECS_STABILITY_HOLD_SECONDS"
		aws ecs wait services-stable \
			--cluster "$CLUSTER_NAME" \
			--services "${SERVICES[@]}"
	fi
fi

ECS_ROLLOUT_TIMEOUT_SECONDS="${ECS_ROLLOUT_TIMEOUT_SECONDS:-900}"
ECS_ROLLOUT_POLL_SECONDS="${ECS_ROLLOUT_POLL_SECONDS:-15}"
printf '\n==> Waiting for ECS service rollout completion for up to %ss\n' "$ECS_ROLLOUT_TIMEOUT_SECONDS"
uv run python -m ecs_rollouts \
	--cluster "$CLUSTER_NAME" \
	--services "${SERVICES[@]}" \
	--timeout-seconds "$ECS_ROLLOUT_TIMEOUT_SECONDS" \
	--poll-seconds "$ECS_ROLLOUT_POLL_SECONDS"

printf '\n==> Running deployed AWS tests\n'
PULUMI_INTEGRATION_TESTS=1 uv run pytest tests/deployed -v

if [[ "$RUN_IDEMPOTENCY" -eq 1 ]]; then
	printf '\n==> Checking for Pulumi no-op preview\n'
	pulumi preview --expect-no-changes --non-interactive --stack "$PULUMI_STACK"
fi
