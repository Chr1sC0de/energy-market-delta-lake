    max_concurrent_runs: {max_concurrent_runs}
run_launcher:
  module: dagster_docker
  class: DockerRunLauncher
  config:
    image: {yaml_quote(aemo_etl_image)}
    env_vars:
      - DAGSTER_POSTGRES_USER
      - DAGSTER_POSTGRES_PASSWORD
      - DAGSTER_POSTGRES_DB
      - DAGSTER_POSTGRES_HOSTNAME
      - AWS_ENDPOINT_URL
      - AWS_DEFAULT_REGION
