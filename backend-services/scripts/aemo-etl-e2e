def render_common_runtime_environment(
    indent: int,
    *,
    include_docker_host: bool = False,
) -> str:
    """Render common service environment variables for compose YAML."""
    values = {
        "DAGSTER_HOME": "/opt/dagster/dagster_home/",
        "DAGSTER_POSTGRES_HOSTNAME": E2E_ENVIRONMENT["DAGSTER_POSTGRES_HOSTNAME"],
        "DAGSTER_POSTGRES_USER": E2E_ENVIRONMENT["DAGSTER_POSTGRES_USER"],
        "DAGSTER_POSTGRES_PASSWORD": E2E_ENVIRONMENT["DAGSTER_POSTGRES_PASSWORD"],
        "DAGSTER_POSTGRES_DB": E2E_ENVIRONMENT["DAGSTER_POSTGRES_DB"],
        "AWS_ENDPOINT_URL": E2E_ENVIRONMENT["AWS_ENDPOINT_URL"],
        "AWS_DEFAULT_REGION": E2E_ENVIRONMENT["AWS_DEFAULT_REGION"],
        "AWS_ACCESS_KEY_ID": E2E_ENVIRONMENT["AWS_ACCESS_KEY_ID"],
        "AWS_SECRET_ACCESS_KEY": E2E_ENVIRONMENT["AWS_SECRET_ACCESS_KEY"],
        "AWS_ALLOW_HTTP": E2E_ENVIRONMENT["AWS_ALLOW_HTTP"],
        "AWS_S3_LOCKING_PROVIDER": E2E_ENVIRONMENT["AWS_S3_LOCKING_PROVIDER"],
        "DAGSTER_FAILURE_ALERT_TOPIC_ARN": E2E_ENVIRONMENT[
            "DAGSTER_FAILURE_ALERT_TOPIC_ARN"
        ],
        "DAGSTER_FAILURE_ALERT_BASE_URL": E2E_ENVIRONMENT[
            "DAGSTER_FAILURE_ALERT_BASE_URL"
        ],
        "DEVELOPMENT_ENVIRONMENT": E2E_ENVIRONMENT["DEVELOPMENT_ENVIRONMENT"],
        "DEVELOPMENT_LOCATION": E2E_ENVIRONMENT["DEVELOPMENT_LOCATION"],
        "NAME_PREFIX": E2E_ENVIRONMENT["NAME_PREFIX"],
    }
    if include_docker_host:
        values = {"DOCKER_HOST": f"unix://{CONTAINER_SOCKET_PATH}", **values}

    prefix = " " * indent
    return "\n".join(
        f"{prefix}{key}: {yaml_quote(value)}" for key, value in values.items()
    )


