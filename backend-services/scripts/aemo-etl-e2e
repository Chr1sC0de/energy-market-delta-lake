class CommandError(RuntimeError):
    """Raised for user-actionable command failures."""


@dataclass(frozen=True, slots=True)
class ImageSpec:
    """Local service image build specification."""

    name: str
    tag: str
    context: Path
    target: str | None = None
    build_args: tuple[tuple[str, str], ...] = ()


@dataclass(frozen=True, slots=True)
class RunOptions:
    """Options for one isolated e2e stack run."""

    rebuild: bool
    reuse: bool
    always_clean: bool
    webserver_port: int
    raw_latest_count: int
    zip_latest_count: int
    timeout_seconds: int
    max_concurrent_runs: int


@dataclass(frozen=True, slots=True)
class ContainerState:
    """Small normalized view of a Podman container state."""

    name: str
    status: str
    exit_code: int | None
    health: str | None


@dataclass(frozen=True, slots=True)
class DagsterRepositorySelector:
    """Dagster GraphQL repository selector values."""

    repository_name: str
    repository_location_name: str

    def to_graphql(self) -> dict[str, str]:
        """Return this selector in Dagster GraphQL input shape."""
        return {
            "repositoryName": self.repository_name,
            "repositoryLocationName": self.repository_location_name,
        }


@dataclass(frozen=True, slots=True)
class DagsterDefinitionState:
    """Relevant Dagster definition state discovered through GraphQL."""

    selector: DagsterRepositorySelector
    max_concurrent_runs: int
    sensors: Mapping[str, str]
    schedules: Mapping[str, str]


@dataclass(frozen=True, slots=True)
class DagsterDataflowStatus:
    """Normalized monitor state for the e2e Dagster dataflow."""

    active_runs: tuple[str, ...]
    failed_runs: tuple[str, ...]
    materialized_target_assets: tuple[str, ...]
    missing_target_assets: tuple[str, ...]
    failed_target_assets: tuple[str, ...]
    missing_asset_checks: tuple[str, ...]
    failed_asset_checks: tuple[str, ...]

    @property
    def target_asset_count(self) -> int:
        """Return the total number of target assets observed by the monitor."""
        return len(self.materialized_target_assets) + len(self.missing_target_assets)

    @property
    def is_successful(self) -> bool:
        """Return whether the full target has reached a successful terminal state."""
        return (
            len(self.active_runs) == 0
            and len(self.failed_runs) == 0
            and len(self.missing_target_assets) == 0
            and len(self.failed_target_assets) == 0
            and len(self.missing_asset_checks) == 0
            and len(self.failed_asset_checks) == 0
            and self.target_asset_count > 0
        )


class CommandRunner:
    """Run external commands."""

    def run(
        self,
        args: Sequence[str],
        *,
        cwd: Path | None = None,
        env: Mapping[str, str] | None = None,
        capture_output: bool = False,
        check: bool = True,
    ) -> subprocess.CompletedProcess[str]:
        """Run a command with consistent text-mode subprocess settings."""
        return subprocess.run(
            list(args),
            cwd=cwd,
            env=dict(env) if env is not None else None,
            capture_output=capture_output,
            text=True,
            check=check,
        )


class DagsterGraphQLClient:
    """Small stdlib GraphQL client for the local Dagster webserver."""

    def __init__(
        self,
        url: str,
        *,
        timeout_seconds: int = DEFAULT_DAGSTER_GRAPHQL_TIMEOUT_SECONDS,
    ) -> None:
        """Initialize the client for one Dagster GraphQL endpoint."""
        self.url = url
        self.timeout_seconds = timeout_seconds

    def execute(
        self,
        query: str,
        variables: Mapping[str, object] | None = None,
    ) -> Mapping[str, object]:
        """Execute a Dagster GraphQL request and return its data payload."""
        body = json.dumps({"query": query, "variables": dict(variables or {})}).encode(
            "utf-8"
        )
        request = Request(
            self.url,
            data=body,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        try:
            with urlopen(request, timeout=self.timeout_seconds) as response:
                payload = json.loads(response.read().decode("utf-8"))
        except URLError as error:
            raise CommandError(
                f"Dagster GraphQL request failed at {self.url}: {error}"
            ) from error
        if not isinstance(payload, dict):
            raise CommandError("Dagster GraphQL returned a non-object payload")
        errors = payload.get("errors")
        if errors:
            raise CommandError(f"Dagster GraphQL returned errors: {errors}")
        data = payload.get("data")
        if not isinstance(data, Mapping):
            raise CommandError("Dagster GraphQL response did not include data")
        return data


def main(argv: Sequence[str] | None = None) -> int:
    """Run the backend-services AEMO ETL e2e command."""
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        if args.command == "run":
            run_stack(
                RunOptions(
                    rebuild=args.rebuild,
                    reuse=args.reuse,
                    always_clean=args.always_clean,
                    webserver_port=args.webserver_port,
                    raw_latest_count=args.raw_latest_count,
                    zip_latest_count=args.zip_latest_count,
                    timeout_seconds=args.timeout_seconds,
                    max_concurrent_runs=args.max_concurrent_runs,
                )
            )
            return 0
    except CommandError as error:
        sys.stderr.write(f"error: {error}\n")
        return 1
    except subprocess.CalledProcessError as error:
        sys.stderr.write(format_called_process_error(error))
        return error.returncode or 1

    parser.error(f"unknown command: {args.command}")
    return 2


def build_parser() -> argparse.ArgumentParser:
    """Build the e2e stack command parser."""
    parser = argparse.ArgumentParser(
        description=(
            "Run the isolated local AEMO ETL End-to-end Dagster stack from "
            "backend-services."
        )
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    run_parser = subparsers.add_parser(
        "run",
        help="start the isolated AEMO ETL e2e Dagster stack",
    )
    run_parser.add_argument(
        "--rebuild",
        action="store_true",
        help="rebuild all local e2e service images before starting",
    )
    run_parser.add_argument(
        "--reuse",
        action="store_true",
        help=(
            "reuse the existing e2e containers and named volumes, and keep "
            "them after a successful start"
        ),
    )
    run_parser.add_argument(
        "--always-clean",
        action="store_true",
        help="clean the e2e containers and named volumes even when startup fails",
    )
    run_parser.add_argument(
        "--webserver-port",
        type=positive_int,
        default=DEFAULT_WEBSERVER_PORT,
        help=f"host port for the e2e Dagster webserver (default: {DEFAULT_WEBSERVER_PORT})",
    )
    run_parser.add_argument(
        "--raw-latest-count",
        type=positive_int,
        default=DEFAULT_RAW_LATEST_COUNT,
        help=(
            "cached raw source-table objects required per table "
            f"(default: {DEFAULT_RAW_LATEST_COUNT})"
        ),
    )
    run_parser.add_argument(
        "--zip-latest-count",
        type=positive_int,
        default=DEFAULT_ZIP_LATEST_COUNT,
        help=(
            "cached zip objects required per domain "
            f"(default: {DEFAULT_ZIP_LATEST_COUNT})"
        ),
    )
    run_parser.add_argument(
        "--timeout-seconds",
        type=positive_int,
        default=DEFAULT_TIMEOUT_SECONDS,
        help=(
            "seconds to wait for the e2e stack and dataflow to complete "
            f"(default: {DEFAULT_TIMEOUT_SECONDS})"
        ),
    )
    run_parser.add_argument(
        "--max-concurrent-runs",
        type=positive_int,
        default=DEFAULT_MAX_CONCURRENT_RUNS,
        help=(
            "Dagster queued run coordinator max_concurrent_runs "
            f"(default: {DEFAULT_MAX_CONCURRENT_RUNS})"
        ),
    )
    return parser


def positive_int(value: str) -> int:
    """Parse a positive integer option value."""
    parsed = int(value)
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be greater than zero")
    return parsed


def run_stack(
    options: RunOptions,
    *,
    runner: CommandRunner | None = None,
    env: Mapping[str, str] | None = None,
) -> None:
    """Start and validate one isolated e2e stack run."""
    if options.reuse and options.always_clean:
        raise CommandError("--reuse and --always-clean cannot be used together")

    command_runner = runner or CommandRunner()
    host_env = dict(os.environ if env is None else env)
    backend_dir = backend_services_dir()
    require_tool("podman")
    require_tool("podman-compose")
    podman_socket = podman_socket_from_xdg_runtime_dir(host_env)

    run_id = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")
    seed_root = backend_dir / ".e2e/aemo-etl"
    run_dir = seed_root / "runs" / run_id
    logs_dir = run_dir / "logs"
    run_dir.mkdir(parents=True, exist_ok=False)
    logs_dir.mkdir(parents=True, exist_ok=True)

    compose_file = run_dir / "compose.yaml"
    dagster_config_file = run_dir / "dagster.yaml"
    workspace_file = run_dir / "workspace.yaml"
    image_specs = build_image_specs(backend_dir)
    compose_command = [
        "podman-compose",
        "--no-ansi",
        "-f",
        str(compose_file),
        "-p",
        STACK_NAME,
    ]
    manifest = base_manifest(
        run_id=run_id,
        run_dir=run_dir,
        compose_file=compose_file,
        dagster_config_file=dagster_config_file,
        workspace_file=workspace_file,
        podman_socket=podman_socket,
        image_specs=image_specs,
        options=options,
    )
    write_json(run_dir / "run-manifest.json", manifest)
    deadline = time.monotonic() + options.timeout_seconds

    try:
        render_runtime_files(
            compose_file=compose_file,
            dagster_config_file=dagster_config_file,
            workspace_file=workspace_file,
            backend_dir=backend_dir,
            seed_root=seed_root,
            podman_socket=podman_socket,
            image_specs=image_specs,
            webserver_port=options.webserver_port,
            raw_latest_count=options.raw_latest_count,
            zip_latest_count=options.zip_latest_count,
            max_concurrent_runs=options.max_concurrent_runs,
        )
        if not options.reuse:
            cleanup_stack(command_runner, compose_command)
        build_required_images(
            command_runner,
            image_specs=image_specs,
            rebuild=options.rebuild,
            cwd=backend_dir,
        )
        up_args = [*compose_command, "up", "-d", "--no-build"]
        if options.reuse and not options.rebuild:
            up_args.append("--no-recreate")
        if options.reuse and options.rebuild:
            up_args.append("--force-recreate")
        command_runner.run(up_args, cwd=backend_dir)
        wait_for_ready_stack(
            command_runner,
            timeout_seconds=remaining_timeout_seconds(deadline),
        )
        manifest["dataflow"] = drive_dagster_dataflow(
            webserver_port=options.webserver_port,
            timeout_seconds=remaining_timeout_seconds(deadline),
            expected_max_concurrent_runs=options.max_concurrent_runs,
            run_id=run_id,
        )
    except Exception as error:
        collect_logs(command_runner, compose_command, logs_dir, backend_dir)
        manifest["status"] = "failed"
        manifest["completed_at"] = now_iso()
        manifest["error"] = str(error)
        manifest["logs_dir"] = str(logs_dir)
        manifest["seed_run_manifest"] = str(seed_root / "seed-run-manifest.json")
        write_json(run_dir / "run-manifest.json", manifest)
        if options.always_clean:
            cleanup_stack(command_runner, compose_command)
            manifest["cleanup"] = "completed-after-failure"
            write_json(run_dir / "run-manifest.json", manifest)
        else:
            manifest["cleanup"] = "preserved-after-failure"
            write_json(run_dir / "run-manifest.json", manifest)
        raise

    collect_logs(command_runner, compose_command, logs_dir, backend_dir)
    manifest["status"] = "success"
    manifest["completed_at"] = now_iso()
    manifest["logs_dir"] = str(logs_dir)
    manifest["seed_run_manifest"] = str(seed_root / "seed-run-manifest.json")
    if options.reuse:
        manifest["cleanup"] = "preserved-for-reuse"
        write_json(run_dir / "run-manifest.json", manifest)
        sys.stdout.write(
            f"{STACK_NAME} completed the dataflow at "
            f"http://localhost:{options.webserver_port}\n"
        )
        sys.stdout.write(f"run manifest: {run_dir / 'run-manifest.json'}\n")
        return

    cleanup_stack(command_runner, compose_command)
    manifest["cleanup"] = "completed-after-success"
    write_json(run_dir / "run-manifest.json", manifest)
    sys.stdout.write(f"{STACK_NAME} completed the dataflow and was cleaned.\n")
    sys.stdout.write(f"run manifest: {run_dir / 'run-manifest.json'}\n")


def backend_services_dir() -> Path:
    """Return the backend-services directory containing this script."""
    return Path(__file__).resolve().parents[1]


def remaining_timeout_seconds(deadline: float) -> int:
    """Return remaining whole seconds before an e2e timeout deadline."""
    remaining = int(deadline - time.monotonic())
    if remaining <= 0:
        raise CommandError("timed out waiting for the e2e stack and dataflow")
    return remaining


def require_tool(name: str) -> None:
    """Fail when a required executable is not on PATH."""
    if shutil.which(name) is None:
        raise CommandError(f"required tool not found on PATH: {name}")


def podman_socket_from_xdg_runtime_dir(env: Mapping[str, str]) -> Path:
    """Return the user Podman socket derived from XDG_RUNTIME_DIR."""
    runtime_dir = env.get("XDG_RUNTIME_DIR")
    if runtime_dir is None or runtime_dir == "":
        raise CommandError(
            "XDG_RUNTIME_DIR is not set; enable the user Podman socket and retry"
        )

    socket_path = Path(runtime_dir) / "podman/podman.sock"
    if not socket_path.exists():
        raise CommandError(
            f"Podman socket does not exist at {socket_path}; run "
            "`systemctl --user enable --now podman.socket` and retry"
        )
    if not socket_path.is_socket():
        raise CommandError(f"Podman socket path is not a socket: {socket_path}")
    return socket_path


def build_image_specs(backend_dir: Path) -> tuple[ImageSpec, ...]:
    """Return the local service images required by the e2e stack."""
    return (
        ImageSpec(
            name="postgres",
            tag=f"localhost/{STACK_NAME}_postgres:latest",
            context=backend_dir / "postgres",
        ),
        ImageSpec(
            name="localstack",
            tag=f"localhost/{STACK_NAME}_localstack:latest",
            context=backend_dir / "localstack",
        ),
        ImageSpec(
            name="aemo-etl",
            tag=f"localhost/{STACK_NAME}_aemo-etl:latest",
            context=backend_dir / "dagster-user/aemo-etl",
            target="dagster-grpc",
        ),
        ImageSpec(
            name="dagster-core",
            tag=f"localhost/{STACK_NAME}_dagster-core:latest",
            context=backend_dir / "dagster-core",
            target="deploy",
            build_args=(("DAGSTER_DEPLOYMENT", "local"),),
        ),
    )


def select_images_to_build(
    existing_images: set[str],
    *,
    image_specs: Sequence[ImageSpec],
    rebuild: bool,
) -> tuple[ImageSpec, ...]:
    """Return image specs that must be built for this run."""
    if rebuild:
        return tuple(image_specs)
    return tuple(spec for spec in image_specs if spec.tag not in existing_images)


def build_required_images(
    runner: CommandRunner,
    *,
    image_specs: Sequence[ImageSpec],
    rebuild: bool,
    cwd: Path,
) -> None:
    """Build missing e2e service images, or all images when rebuild is set."""
    existing_images = {
        spec.tag
        for spec in image_specs
        if runner.run(
            ["podman", "image", "exists", spec.tag],
            cwd=cwd,
            check=False,
        ).returncode
        == 0
    }
    for spec in select_images_to_build(
        existing_images,
        image_specs=image_specs,
        rebuild=rebuild,
    ):
        sys.stdout.write(f"building {spec.name}: {spec.tag}\n")
        build_args = ["podman", "build", "-t", spec.tag]
        if spec.target is not None:
            build_args.extend(["--target", spec.target])
        for key, value in spec.build_args:
            build_args.extend(["--build-arg", f"{key}={value}"])
        build_args.append(str(spec.context))
        runner.run(build_args, cwd=cwd)


def render_runtime_files(
    *,
    compose_file: Path,
    dagster_config_file: Path,
    workspace_file: Path,
    backend_dir: Path,
    seed_root: Path,
    podman_socket: Path,
    image_specs: Sequence[ImageSpec],
    webserver_port: int,
    raw_latest_count: int,
    zip_latest_count: int,
    max_concurrent_runs: int,
) -> None:
    """Render the compose and Dagster runtime files for this e2e run."""
    images = {spec.name: spec.tag for spec in image_specs}
    compose_file.write_text(
        render_compose_yaml(
            images=images,
            seed_root=seed_root,
            podman_socket=podman_socket,
            dagster_config_file=dagster_config_file,
            workspace_file=workspace_file,
            webserver_port=webserver_port,
            raw_latest_count=raw_latest_count,
            zip_latest_count=zip_latest_count,
        ),
        encoding="utf-8",
    )
    dagster_config_file.write_text(
        render_dagster_yaml(
            aemo_etl_image=images["aemo-etl"],
            podman_socket=podman_socket,
            max_concurrent_runs=max_concurrent_runs,
        ),
        encoding="utf-8",
    )
    workspace_file.write_text(render_workspace_yaml(), encoding="utf-8")
    seed_root.mkdir(parents=True, exist_ok=True)
    backend_dir.joinpath(".e2e/aemo-etl").mkdir(parents=True, exist_ok=True)


