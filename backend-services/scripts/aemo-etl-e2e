class CommandError(RuntimeError):
    """Raised for user-actionable command failures."""


@dataclass(frozen=True, slots=True)
class ImageSpec:
    """Local service image build specification."""

    name: str
    tag: str
    context: Path
    target: str | None = None
    build_args: tuple[tuple[str, str], ...] = ()


@dataclass(frozen=True, slots=True)
class RunOptions:
    """Options for one isolated e2e stack run."""

    scenario: str
    rebuild: bool
    reuse: bool
    always_clean: bool
    seed_root: Path | None
    webserver_port: int
    raw_latest_count: int
    zip_latest_count: int
    timeout_seconds: int
    max_concurrent_runs: int


@dataclass(frozen=True, slots=True)
class ContainerState:
    """Small normalized view of a Podman container state."""

    name: str
    status: str
    exit_code: int | None
    health: str | None


@dataclass(frozen=True, slots=True)
class DagsterRepositorySelector:
    """Dagster GraphQL repository selector values."""

    repository_name: str
    repository_location_name: str

    def to_graphql(self) -> dict[str, str]:
        """Return this selector in Dagster GraphQL input shape."""
        return {
            "repositoryName": self.repository_name,
            "repositoryLocationName": self.repository_location_name,
        }


@dataclass(frozen=True, slots=True)
class DagsterDefinitionState:
    """Relevant Dagster definition state discovered through GraphQL."""

    selector: DagsterRepositorySelector
    max_concurrent_runs: int
    sensors: Mapping[str, str]
    schedules: Mapping[str, str]


@dataclass(frozen=True, slots=True)
class DagsterDataflowStatus:
    """Normalized monitor state for the e2e Dagster dataflow."""

    active_runs: tuple[str, ...]
    failed_runs: tuple[str, ...]
    materialized_target_assets: tuple[str, ...]
    missing_target_assets: tuple[str, ...]
    failed_target_assets: tuple[str, ...]
    missing_asset_checks: tuple[str, ...]
    failed_asset_checks: tuple[str, ...]
    run_status_counts: Mapping[str, int] = field(default_factory=dict)
    target_materialization_timestamps: tuple[float, ...] = ()

    @property
    def target_asset_count(self) -> int:
        """Return the total number of target assets observed by the monitor."""
        return len(self.materialized_target_assets) + len(self.missing_target_assets)

    @property
    def active_run_count(self) -> int:
        """Return active non-queued runs from the observed run statuses."""
        return sum(
            self.run_status_counts.get(status, 0)
            for status in ACTIVE_RUN_STATUSES
            if status != "QUEUED"
        )

    @property
    def queued_run_count(self) -> int:
        """Return queued runs from the observed run statuses."""
        return self.run_status_counts.get("QUEUED", 0)

    @property
    def is_successful(self) -> bool:
        """Return whether the full target has reached a successful terminal state."""
        return (
            len(self.failed_runs) == 0
            and len(self.missing_target_assets) == 0
            and len(self.failed_target_assets) == 0
            and len(self.missing_asset_checks) == 0
            and len(self.failed_asset_checks) == 0
            and self.target_asset_count > 0
        )


@dataclass(slots=True)
class DagsterDataflowTelemetry:
    """Aggregated telemetry from Dagster dataflow monitor samples."""

    sample_count: int = 0
    peak_active_run_count: int = 0
    peak_queued_run_count: int = 0
    final_run_status_counts: dict[str, int] = field(default_factory=dict)
    final_target_asset_count: int = 0
    final_materialized_target_asset_count: int = 0
    final_missing_target_asset_count: int = 0
    final_failed_target_asset_count: int = 0
    first_target_materialization_timestamp: float | None = None
    last_target_materialization_timestamp: float | None = None
    final_failed_asset_check_count: int = 0

    def record_status_sample(self, status: DagsterDataflowStatus) -> None:
        """Record one normalized Dagster monitor status sample."""
        self.sample_count += 1
        self.peak_active_run_count = max(
            self.peak_active_run_count,
            status.active_run_count,
        )
        self.peak_queued_run_count = max(
            self.peak_queued_run_count,
            status.queued_run_count,
        )
        self.final_run_status_counts = dict(sorted(status.run_status_counts.items()))
        self.final_target_asset_count = status.target_asset_count
        self.final_materialized_target_asset_count = len(
            status.materialized_target_assets
        )
        self.final_missing_target_asset_count = len(status.missing_target_assets)
        self.final_failed_target_asset_count = len(status.failed_target_assets)
        self.final_failed_asset_check_count = len(status.failed_asset_checks)
        self.record_target_materialization_timestamps(
            status.target_materialization_timestamps
        )

    def record_target_materialization_timestamps(
        self,
        timestamps: Sequence[float],
    ) -> None:
        """Record observed target materialization timestamps."""
        for timestamp in timestamps:
            if self.first_target_materialization_timestamp is None:
                self.first_target_materialization_timestamp = timestamp
            else:
                self.first_target_materialization_timestamp = min(
                    self.first_target_materialization_timestamp,
                    timestamp,
                )

            if self.last_target_materialization_timestamp is None:
                self.last_target_materialization_timestamp = timestamp
            else:
                self.last_target_materialization_timestamp = max(
                    self.last_target_materialization_timestamp,
                    timestamp,
                )

    def to_manifest(self) -> dict[str, object]:
        """Return this telemetry in the run manifest shape."""
        return {
            "sample_count": self.sample_count,
            "peak_active_run_count": self.peak_active_run_count,
            "peak_queued_run_count": self.peak_queued_run_count,
            "final_run_status_counts": self.final_run_status_counts,
            "final_target_progress": {
                "materialized_target_asset_count": (
                    self.final_materialized_target_asset_count
                ),
                "target_asset_count": self.final_target_asset_count,
                "missing_target_asset_count": self.final_missing_target_asset_count,
                "failed_target_asset_count": self.final_failed_target_asset_count,
            },
            "first_target_materialization_at": timestamp_iso_or_none(
                self.first_target_materialization_timestamp
            ),
            "last_target_materialization_at": timestamp_iso_or_none(
                self.last_target_materialization_timestamp
            ),
            "final_failed_asset_check_count": self.final_failed_asset_check_count,
        }


@dataclass(slots=True)
class GateRunTelemetry:
    """Structured timing telemetry for one e2e gate run."""

    started_monotonic: float
    completed_monotonic: float | None = None
    stack_startup_duration_seconds: float | None = None
    dagster_dataflow_monitor_duration_seconds: float | None = None
    cleanup_duration_seconds: float = 0.0
    cleanup_phases: list[dict[str, object]] = field(default_factory=list)
    dataflow: DagsterDataflowTelemetry | None = None

    @classmethod
    def start(cls) -> "GateRunTelemetry":
        """Start timing one e2e gate run."""
        return cls(started_monotonic=time.monotonic())

    def ensure_dataflow(self) -> DagsterDataflowTelemetry:
        """Return the dataflow telemetry accumulator for this gate run."""
        if self.dataflow is None:
            self.dataflow = DagsterDataflowTelemetry()
        return self.dataflow

    def record_stack_startup(self, started: float, completed: float) -> None:
        """Record stack startup timing."""
        self.stack_startup_duration_seconds = elapsed_seconds(started, completed)

    def record_dagster_dataflow_monitor(
        self,
        started: float,
        completed: float,
    ) -> None:
        """Record Dagster dataflow monitor timing."""
        self.dagster_dataflow_monitor_duration_seconds = elapsed_seconds(
            started,
            completed,
        )

    def record_cleanup(
        self,
        phase: str,
        started: float,
        completed: float,
        *,
        issues: Sequence[Mapping[str, object]] = (),
    ) -> None:
        """Record one cleanup phase."""
        duration = elapsed_seconds(started, completed)
        status = "completed"
        if any(issue.get("severity") == "error" for issue in issues):
            status = "incomplete"
        elif len(issues) > 0:
            status = "completed-with-warnings"
        phase_payload: dict[str, object] = {
            "phase": phase,
            "duration_seconds": round_duration_seconds(duration),
            "status": status,
        }
        if len(issues) > 0:
            phase_payload["issues"] = [dict(issue) for issue in issues]
        self.cleanup_duration_seconds += duration
        self.cleanup_phases.append(phase_payload)

    def complete(self) -> None:
        """Mark the total e2e gate run timing as complete."""
        self.completed_monotonic = time.monotonic()

    def to_manifest(self) -> dict[str, object]:
        """Return this telemetry in the run manifest shape."""
        completed = self.completed_monotonic
        if completed is None:
            completed = time.monotonic()

        payload: dict[str, object] = {
            "total_gate_duration_seconds": round_duration_seconds(
                elapsed_seconds(self.started_monotonic, completed)
            ),
            "stack_startup_duration_seconds": optional_duration_seconds(
                self.stack_startup_duration_seconds
            ),
            "dagster_dataflow_monitor_duration_seconds": optional_duration_seconds(
                self.dagster_dataflow_monitor_duration_seconds
            ),
            "cleanup_duration_seconds": round_duration_seconds(
                self.cleanup_duration_seconds
            ),
            "cleanup_phases": self.cleanup_phases,
        }
        if self.dataflow is not None:
            payload["dagster_dataflow"] = self.dataflow.to_manifest()
        return payload


class CommandRunner:
    """Run external commands."""

    def run(
        self,
        args: Sequence[str],
        *,
        cwd: Path | None = None,
        env: Mapping[str, str] | None = None,
        capture_output: bool = False,
        check: bool = True,
    ) -> subprocess.CompletedProcess[str]:
        """Run a command with consistent text-mode subprocess settings."""
        return subprocess.run(
            list(args),
            cwd=cwd,
            env=dict(env) if env is not None else None,
            capture_output=capture_output,
            text=True,
            check=check,
        )


class DagsterGraphQLClient:
    """Small stdlib GraphQL client for the local Dagster webserver."""

    def __init__(
        self,
        url: str,
        *,
        timeout_seconds: int = DEFAULT_DAGSTER_GRAPHQL_TIMEOUT_SECONDS,
    ) -> None:
        """Initialize the client for one Dagster GraphQL endpoint."""
        self.url = url
        self.timeout_seconds = timeout_seconds

    def execute(
        self,
        query: str,
        variables: Mapping[str, object] | None = None,
        *,
        timeout_seconds: int | None = None,
    ) -> Mapping[str, object]:
        """Execute a Dagster GraphQL request and return its data payload."""
        body = json.dumps({"query": query, "variables": dict(variables or {})}).encode(
            "utf-8"
        )
        request = Request(
            self.url,
            data=body,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        request_timeout_seconds = (
            self.timeout_seconds if timeout_seconds is None else timeout_seconds
        )
        try:
            with urlopen(request, timeout=request_timeout_seconds) as response:
                payload = json.loads(response.read().decode("utf-8"))
        except OSError as error:
            raise CommandError(
                f"Dagster GraphQL request failed at {self.url}: {error}"
            ) from error
        if not isinstance(payload, dict):
            raise CommandError("Dagster GraphQL returned a non-object payload")
        errors = payload.get("errors")
        if errors:
            raise CommandError(f"Dagster GraphQL returned errors: {errors}")
        data = payload.get("data")
        if not isinstance(data, Mapping):
            raise CommandError("Dagster GraphQL response did not include data")
        return data


def main(argv: Sequence[str] | None = None) -> int:
    """Run the backend-services AEMO ETL e2e command."""
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        if args.command == "run":
            run_stack(run_options_from_args(args))
            return 0
    except CommandError as error:
        sys.stderr.write(f"error: {error}\n")
        return 1
    except subprocess.CalledProcessError as error:
        sys.stderr.write(format_called_process_error(error))
        return error.returncode or 1

    parser.error(f"unknown command: {args.command}")
    return 2


def build_parser() -> argparse.ArgumentParser:
    """Build the e2e stack command parser."""
    parser = argparse.ArgumentParser(
        description=(
            "Run the isolated local AEMO ETL End-to-end Dagster stack from "
            "backend-services."
        )
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    run_parser = subparsers.add_parser(
        "run",
        help="start the isolated AEMO ETL e2e Dagster stack",
    )
    run_parser.add_argument(
        "--scenario",
        choices=tuple(E2E_SCENARIO_DEFAULTS),
        default=FULL_GAS_MODEL_SCENARIO,
        help=(
            "named e2e target profile "
            f"(default: {FULL_GAS_MODEL_SCENARIO}; "
            f"Promotion gate: {PROMOTION_GAS_MODEL_SCENARIO})"
        ),
    )
    run_parser.add_argument(
        "--rebuild",
        action="store_true",
        help="rebuild all local e2e service images before starting",
    )
    run_parser.add_argument(
        "--reuse",
        action="store_true",
        help=(
            "reuse the existing e2e containers and named volumes, and keep "
            "them after a successful start"
        ),
    )
    run_parser.add_argument(
        "--always-clean",
        action="store_true",
        help="clean the e2e containers and named volumes even when startup fails",
    )
    run_parser.add_argument(
        "--seed-root",
        type=Path,
        default=None,
        help=(
            "cached Archive seed root to mount into the isolated stack "
            "(default: backend-services/.e2e/aemo-etl)"
        ),
    )
    run_parser.add_argument(
        "--webserver-port",
        type=positive_int,
        default=DEFAULT_WEBSERVER_PORT,
        help=f"host port for the e2e Dagster webserver (default: {DEFAULT_WEBSERVER_PORT})",
    )
    run_parser.add_argument(
        "--raw-latest-count",
        type=positive_int,
        default=None,
        help=(
            "cached raw source-table objects required per table "
            "(default: scenario-specific)"
        ),
    )
    run_parser.add_argument(
        "--zip-latest-count",
        type=positive_int,
        default=None,
        help=(
            "cached zip objects required per domain "
            "(default: scenario-specific)"
        ),
    )
    run_parser.add_argument(
        "--timeout-seconds",
        type=positive_int,
        default=None,
        help=(
            "seconds to wait for the e2e stack and dataflow to complete "
            "(default: scenario-specific)"
        ),
    )
    run_parser.add_argument(
        "--max-concurrent-runs",
        type=positive_int,
        default=None,
        help=(
            "Dagster queued run coordinator max_concurrent_runs "
            "(default: scenario-specific)"
        ),
    )
    return parser


def run_options_from_args(args: argparse.Namespace) -> RunOptions:
    """Resolve run options from CLI args and the selected e2e scenario."""
    scenario = expect_str(getattr(args, "scenario", None), "e2e scenario")
    scenario_defaults = E2E_SCENARIO_DEFAULTS.get(scenario)
    if scenario_defaults is None:
        raise CommandError(f"unknown e2e scenario: {scenario}")
    return RunOptions(
        scenario=scenario,
        rebuild=bool(args.rebuild),
        reuse=bool(args.reuse),
        always_clean=bool(args.always_clean),
        seed_root=args.seed_root,
        webserver_port=args.webserver_port,
        raw_latest_count=args.raw_latest_count
        or scenario_defaults["raw_latest_count"],
        zip_latest_count=args.zip_latest_count
        or scenario_defaults["zip_latest_count"],
        timeout_seconds=args.timeout_seconds
        or scenario_defaults["timeout_seconds"],
        max_concurrent_runs=args.max_concurrent_runs
        or scenario_defaults["max_concurrent_runs"],
    )


def positive_int(value: str) -> int:
    """Parse a positive integer option value."""
    parsed = int(value)
    if parsed <= 0:
        raise argparse.ArgumentTypeError("must be greater than zero")
    return parsed


def run_stack(
    options: RunOptions,
    *,
    runner: CommandRunner | None = None,
    env: Mapping[str, str] | None = None,
) -> None:
    """Start and validate one isolated e2e stack run."""
    if options.reuse and options.always_clean:
        raise CommandError("--reuse and --always-clean cannot be used together")

    telemetry = GateRunTelemetry.start()
    command_runner = runner or CommandRunner()
    host_env = dict(os.environ if env is None else env)
    backend_dir = backend_services_dir()
    require_tool("podman")
    require_tool("podman-compose")
    podman_socket = podman_socket_from_xdg_runtime_dir(host_env)

    run_id = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")
    seed_root = (options.seed_root or backend_dir / ".e2e/aemo-etl").resolve()
    run_dir = seed_root / "runs" / run_id
    logs_dir = run_dir / "logs"
    run_dir.mkdir(parents=True, exist_ok=False)
    logs_dir.mkdir(parents=True, exist_ok=True)

    compose_file = run_dir / "compose.yaml"
    dagster_config_file = run_dir / "dagster.yaml"
    workspace_file = run_dir / "workspace.yaml"
    image_specs = build_image_specs(backend_dir)
    compose_command = [
        "podman-compose",
        "--no-ansi",
        "-f",
        str(compose_file),
        "-p",
        STACK_NAME,
    ]
    manifest = base_manifest(
        run_id=run_id,
        run_dir=run_dir,
        compose_file=compose_file,
        dagster_config_file=dagster_config_file,
        workspace_file=workspace_file,
        podman_socket=podman_socket,
        image_specs=image_specs,
        options=options,
    )
    manifest_path = run_dir / "run-manifest.json"
    write_run_manifest(manifest_path, manifest, telemetry)
    deadline = time.monotonic() + options.timeout_seconds

    try:
        render_runtime_files(
            compose_file=compose_file,
            dagster_config_file=dagster_config_file,
            workspace_file=workspace_file,
            backend_dir=backend_dir,
            seed_root=seed_root,
            podman_socket=podman_socket,
            image_specs=image_specs,
            webserver_port=options.webserver_port,
            raw_latest_count=options.raw_latest_count,
            zip_latest_count=options.zip_latest_count,
            max_concurrent_runs=options.max_concurrent_runs,
        )
        if not options.reuse:
            cleanup_stack_with_telemetry(
                command_runner,
                compose_command,
                telemetry=telemetry,
                phase="pre-run",
            )
        build_required_images(
            command_runner,
            image_specs=image_specs,
            rebuild=options.rebuild,
            cwd=backend_dir,
        )
        stack_startup_started = time.monotonic()
        try:
            start_stack_services(
                command_runner,
                compose_command,
                backend_dir=backend_dir,
                options=options,
                deadline=deadline,
            )
            wait_for_ready_stack(
                command_runner,
                timeout_seconds=remaining_timeout_seconds(deadline),
            )
        finally:
            telemetry.record_stack_startup(
                stack_startup_started,
                time.monotonic(),
            )
        manifest["dataflow"] = drive_dagster_dataflow(
            webserver_port=options.webserver_port,
            timeout_seconds=remaining_timeout_seconds(deadline),
            expected_max_concurrent_runs=options.max_concurrent_runs,
            run_id=run_id,
            runner=command_runner,
            telemetry=telemetry,
        )
    except Exception as error:
        collect_logs(command_runner, compose_command, logs_dir, backend_dir)
        manifest["status"] = "failed"
        manifest["completed_at"] = now_iso()
        manifest["error"] = str(error)
        manifest["logs_dir"] = str(logs_dir)
        manifest["seed_run_manifest"] = str(seed_root / "seed-run-manifest.json")
        write_run_manifest(manifest_path, manifest, telemetry)
        if options.always_clean:
            cleanup_issues = cleanup_stack_with_telemetry(
                command_runner,
                compose_command,
                telemetry=telemetry,
                phase="post-failure",
            )
            manifest["cleanup"] = cleanup_manifest_status(
                base_status="completed-after-failure",
                warning_status="completed-with-warnings-after-failure",
                error_status="incomplete-after-failure",
                issues=cleanup_issues,
            )
            if len(cleanup_issues) > 0:
                manifest["cleanup_issues"] = cleanup_issues
        else:
            manifest["cleanup"] = "preserved-after-failure"
        telemetry.complete()
        emit_e2e_budget_report(telemetry)
        write_run_manifest(manifest_path, manifest, telemetry)
        raise

    collect_logs(command_runner, compose_command, logs_dir, backend_dir)
    manifest["status"] = "success"
    manifest["completed_at"] = now_iso()
    manifest["logs_dir"] = str(logs_dir)
    manifest["seed_run_manifest"] = str(seed_root / "seed-run-manifest.json")
    if options.reuse:
        manifest["cleanup"] = "preserved-for-reuse"
        telemetry.complete()
        emit_e2e_budget_report(telemetry)
        write_run_manifest(manifest_path, manifest, telemetry)
        sys.stdout.write(
            f"{STACK_NAME} completed the dataflow at "
            f"http://localhost:{options.webserver_port}\n"
        )
        sys.stdout.write(f"run manifest: {run_dir / 'run-manifest.json'}\n")
        return

    cleanup_issues = cleanup_stack_with_telemetry(
        command_runner,
        compose_command,
        telemetry=telemetry,
        phase="post-success",
    )
    manifest["cleanup"] = cleanup_manifest_status(
        base_status="completed-after-success",
        warning_status="completed-with-warnings-after-success",
        error_status="incomplete-after-success",
        issues=cleanup_issues,
    )
    if len(cleanup_issues) > 0:
        manifest["cleanup_issues"] = cleanup_issues
    telemetry.complete()
    emit_e2e_budget_report(telemetry)
    write_run_manifest(manifest_path, manifest, telemetry)
    if cleanup_has_errors(cleanup_issues):
        sys.stdout.write(
            f"{STACK_NAME} completed the dataflow with incomplete cleanup.\n"
        )
    elif len(cleanup_issues) > 0:
        sys.stdout.write(
            f"{STACK_NAME} completed the dataflow with cleanup warnings.\n"
        )
    else:
        sys.stdout.write(f"{STACK_NAME} completed the dataflow and was cleaned.\n")
    sys.stdout.write(f"run manifest: {run_dir / 'run-manifest.json'}\n")


def backend_services_dir() -> Path:
    """Return the backend-services directory containing this script."""
    return Path(__file__).resolve().parents[1]


def remaining_timeout_seconds(deadline: float) -> int:
    """Return remaining whole seconds before an e2e timeout deadline."""
    remaining = int(deadline - time.monotonic())
    if remaining <= 0:
        raise CommandError("timed out waiting for the e2e stack and dataflow")
    return remaining


def require_tool(name: str) -> None:
    """Fail when a required executable is not on PATH."""
    if shutil.which(name) is None:
        raise CommandError(f"required tool not found on PATH: {name}")


def podman_socket_from_xdg_runtime_dir(env: Mapping[str, str]) -> Path:
    """Return the user Podman socket derived from XDG_RUNTIME_DIR."""
    runtime_dir = env.get("XDG_RUNTIME_DIR")
    if runtime_dir is None or runtime_dir == "":
        raise CommandError(
            "XDG_RUNTIME_DIR is not set; enable the user Podman socket and retry"
        )

    socket_path = Path(runtime_dir) / "podman/podman.sock"
    if not socket_path.exists():
        raise CommandError(
            f"Podman socket does not exist at {socket_path}; run "
            "`systemctl --user enable --now podman.socket` and retry"
        )
    if not socket_path.is_socket():
        raise CommandError(f"Podman socket path is not a socket: {socket_path}")
    return socket_path


def build_image_specs(backend_dir: Path) -> tuple[ImageSpec, ...]:
    """Return the local service images required by the e2e stack."""
    return (
        ImageSpec(
            name="postgres",
            tag=f"localhost/{STACK_NAME}_postgres:latest",
            context=backend_dir / "postgres",
        ),
        ImageSpec(
            name="localstack",
            tag=f"localhost/{STACK_NAME}_localstack:latest",
            context=backend_dir / "localstack",
        ),
        ImageSpec(
            name="aemo-etl",
            tag=f"localhost/{STACK_NAME}_aemo-etl:latest",
            context=backend_dir / "dagster-user/aemo-etl",
            target="dagster-grpc",
        ),
        ImageSpec(
            name="dagster-core",
            tag=f"localhost/{STACK_NAME}_dagster-core:latest",
            context=backend_dir / "dagster-core",
            target="deploy",
            build_args=(("DAGSTER_DEPLOYMENT", "local"),),
        ),
    )


def select_images_to_build(
    existing_images: set[str],
    *,
    image_specs: Sequence[ImageSpec],
    rebuild: bool,
) -> tuple[ImageSpec, ...]:
    """Return image specs that must be built for this run."""
    if rebuild:
        return tuple(image_specs)
    return tuple(spec for spec in image_specs if spec.tag not in existing_images)


def build_required_images(
    runner: CommandRunner,
    *,
    image_specs: Sequence[ImageSpec],
    rebuild: bool,
    cwd: Path,
) -> None:
    """Build missing e2e service images, or all images when rebuild is set."""
    existing_images = {
        spec.tag
        for spec in image_specs
        if runner.run(
            ["podman", "image", "exists", spec.tag],
            cwd=cwd,
            check=False,
        ).returncode
        == 0
    }
    for spec in select_images_to_build(
        existing_images,
        image_specs=image_specs,
        rebuild=rebuild,
    ):
        sys.stdout.write(f"building {spec.name}: {spec.tag}\n")
        build_args = ["podman", "build", "-t", spec.tag]
        if spec.target is not None:
            build_args.extend(["--target", spec.target])
        for key, value in spec.build_args:
            build_args.extend(["--build-arg", f"{key}={value}"])
        build_args.append(str(spec.context))
        runner.run(build_args, cwd=cwd)


def start_stack_services(
    runner: CommandRunner,
    compose_command: Sequence[str],
    *,
    backend_dir: Path,
    options: RunOptions,
    deadline: float,
) -> None:
    """Start the compose services in dependency phases for Podman."""
    runner.run(
        compose_up_args(
            compose_command,
            services=FOUNDATION_SERVICE_NAMES,
            detach=True,
            options=options,
        ),
        cwd=backend_dir,
    )
    wait_for_containers_ready(
        runner,
        container_names=FOUNDATION_CONTAINERS,
        timeout_seconds=remaining_timeout_seconds(deadline),
    )

    runner.run(
        compose_up_args(
            compose_command,
            services=SEED_SERVICE_NAMES,
            detach=False,
            options=options,
        ),
        cwd=backend_dir,
    )
    wait_for_containers_ready(
        runner,
        container_names=(SEED_CONTAINER,),
        timeout_seconds=remaining_timeout_seconds(deadline),
    )

    runner.run(
        compose_up_args(
            compose_command,
            services=AEMO_ETL_SERVICE_NAMES,
            detach=True,
            options=options,
        ),
        cwd=backend_dir,
    )
    wait_for_containers_ready(
        runner,
        container_names=(AEMO_ETL_CONTAINER,),
        timeout_seconds=remaining_timeout_seconds(deadline),
    )

    runner.run(
        compose_up_args(
            compose_command,
            services=DAGSTER_SERVICE_NAMES,
            detach=True,
            options=options,
        ),
        cwd=backend_dir,
    )


def compose_up_args(
    compose_command: Sequence[str],
    *,
    services: Sequence[str],
    detach: bool,
    options: RunOptions,
) -> list[str]:
    """Return a podman-compose up command with options before services."""
    args = [*compose_command, "up"]
    if detach:
        args.append("-d")
    args.append("--no-build")
    if options.reuse and not options.rebuild:
        args.append("--no-recreate")
    if options.reuse and options.rebuild:
        args.append("--force-recreate")
    args.extend(services)
    return args


def render_runtime_files(
    *,
    compose_file: Path,
    dagster_config_file: Path,
    workspace_file: Path,
    backend_dir: Path,
    seed_root: Path,
    podman_socket: Path,
    image_specs: Sequence[ImageSpec],
    webserver_port: int,
    raw_latest_count: int,
    zip_latest_count: int,
    max_concurrent_runs: int,
) -> None:
    """Render the compose and Dagster runtime files for this e2e run."""
    images = {spec.name: spec.tag for spec in image_specs}
    compose_file.write_text(
        render_compose_yaml(
            images=images,
            seed_root=seed_root,
            podman_socket=podman_socket,
            dagster_config_file=dagster_config_file,
            workspace_file=workspace_file,
            webserver_port=webserver_port,
            raw_latest_count=raw_latest_count,
            zip_latest_count=zip_latest_count,
        ),
        encoding="utf-8",
    )
    dagster_config_file.write_text(
        render_dagster_yaml(
            aemo_etl_image=images["aemo-etl"],
            podman_socket=podman_socket,
            max_concurrent_runs=max_concurrent_runs,
        ),
        encoding="utf-8",
    )
    workspace_file.write_text(render_workspace_yaml(), encoding="utf-8")
    seed_root.mkdir(parents=True, exist_ok=True)
    backend_dir.joinpath(".e2e/aemo-etl").mkdir(parents=True, exist_ok=True)


def render_compose_yaml(
    *,
    images: Mapping[str, str],
    seed_root: Path,
    podman_socket: Path,
    dagster_config_file: Path,
    workspace_file: Path,
    webserver_port: int,
    raw_latest_count: int,
    zip_latest_count: int,
) -> str:
    """Return the isolated e2e compose file."""
    socket_volume = f"{podman_socket}:{CONTAINER_SOCKET_PATH}"
    dagster_config_volume = (
        f"{dagster_config_file}:/opt/dagster/dagster_home/dagster.yaml:ro"
    )
    workspace_volume = f"{workspace_file}:/opt/dagster/dagster_home/workspace.yaml:ro"
    seed_volume = f"{seed_root}:/var/lib/aemo-etl/e2e-seed"
    return f"""# Generated by backend-services/scripts/aemo-etl-e2e.
name: {STACK_NAME}

networks:
  dagster_network:
    name: {NETWORK_NAME}
    driver: bridge

volumes:
  postgres_data:
  localstack_data:

services:
  postgres:
    image: {yaml_quote(images["postgres"])}
    container_name: {POSTGRES_CONTAINER}
    networks:
      - dagster_network
    environment:
      POSTGRES_USER: {yaml_quote(E2E_ENVIRONMENT["POSTGRES_USER"])}
      POSTGRES_PASSWORD: {yaml_quote(E2E_ENVIRONMENT["POSTGRES_PASSWORD"])}
      POSTGRES_DB: {yaml_quote(E2E_ENVIRONMENT["POSTGRES_DB"])}
      DAGSTER_POSTGRES_USER: {yaml_quote(E2E_ENVIRONMENT["DAGSTER_POSTGRES_USER"])}
      DAGSTER_POSTGRES_PASSWORD: {yaml_quote(E2E_ENVIRONMENT["DAGSTER_POSTGRES_PASSWORD"])}
      DAGSTER_POSTGRES_DB: {yaml_quote(E2E_ENVIRONMENT["DAGSTER_POSTGRES_DB"])}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s

  localstack:
    image: {yaml_quote(images["localstack"])}
    container_name: {LOCALSTACK_CONTAINER}
    networks:
      - dagster_network
    environment:
      SERVICES: "s3,dynamodb"
      AWS_DEFAULT_REGION: {yaml_quote(E2E_ENVIRONMENT["AWS_DEFAULT_REGION"])}
    volumes:
      - localstack_data:/var/lib/localstack
      - {yaml_quote(socket_volume)}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:4566/_localstack/health | grep -q '\\\"s3\\\"' && curl -sf http://localhost:4566/_localstack/health | grep -q '\\\"dynamodb\\\"'"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 15s

  aemo-etl-seed-localstack:
    image: {yaml_quote(images["aemo-etl"])}
    container_name: {SEED_CONTAINER}
    networks:
      - dagster_network
    environment:
      AWS_ENDPOINT_URL: {yaml_quote(E2E_ENVIRONMENT["AWS_ENDPOINT_URL"])}
      AWS_DEFAULT_REGION: {yaml_quote(E2E_ENVIRONMENT["AWS_DEFAULT_REGION"])}
      AWS_ACCESS_KEY_ID: {yaml_quote(E2E_ENVIRONMENT["AWS_ACCESS_KEY_ID"])}
      AWS_SECRET_ACCESS_KEY: {yaml_quote(E2E_ENVIRONMENT["AWS_SECRET_ACCESS_KEY"])}
      AWS_ALLOW_HTTP: {yaml_quote(E2E_ENVIRONMENT["AWS_ALLOW_HTTP"])}
      DEVELOPMENT_ENVIRONMENT: {yaml_quote(E2E_ENVIRONMENT["DEVELOPMENT_ENVIRONMENT"])}
      DEVELOPMENT_LOCATION: {yaml_quote(E2E_ENVIRONMENT["DEVELOPMENT_LOCATION"])}
      NAME_PREFIX: {yaml_quote(E2E_ENVIRONMENT["NAME_PREFIX"])}
      LANDING_BUCKET: {yaml_quote(E2E_ENVIRONMENT["LANDING_BUCKET"])}
      ARCHIVE_BUCKET: {yaml_quote(E2E_ENVIRONMENT["ARCHIVE_BUCKET"])}
      AEMO_ETL_E2E_SEED_ROOT: /var/lib/aemo-etl/e2e-seed
      AEMO_ETL_E2E_SEED_RAW_LATEST_COUNT: {raw_latest_count}
      AEMO_ETL_E2E_SEED_ZIP_LATEST_COUNT: {zip_latest_count}
    volumes:
      - {yaml_quote(seed_volume)}
    command:
      - aemo-e2e-archive-seed
      - load-localstack
      - --seed-root
      - /var/lib/aemo-etl/e2e-seed
      - --archive-bucket
      - {yaml_quote(E2E_ENVIRONMENT["ARCHIVE_BUCKET"])}
      - --landing-bucket
      - {yaml_quote(E2E_ENVIRONMENT["LANDING_BUCKET"])}
      - --raw-latest-count
      - {yaml_quote(str(raw_latest_count))}
      - --zip-latest-count
      - {yaml_quote(str(zip_latest_count))}

  aemo-etl:
    image: {yaml_quote(images["aemo-etl"])}
    container_name: {AEMO_ETL_CONTAINER}
    networks:
      - dagster_network
    environment:
{render_common_runtime_environment(6)}
    healthcheck:
      test: ["CMD-SHELL", "dagster api grpc-health-check -p 4000"]
      interval: 3s
      timeout: 1s
      retries: 20
      start_period: 3s
    command:
      - dagster
      - code-server
      - start
      - -h
      - "0.0.0.0"
      - -p
      - "4000"
      - -m
      - aemo_etl.definitions

  dagster-webserver:
    image: {yaml_quote(images["dagster-core"])}
    container_name: {DAGSTER_WEBSERVER_CONTAINER}
    networks:
      - dagster_network
    ports:
      - {yaml_quote(f"127.0.0.1:{webserver_port}:3000")}
    environment:
{render_common_runtime_environment(6, include_docker_host=True)}
    volumes:
      - {yaml_quote(socket_volume)}
      - {yaml_quote(dagster_config_volume)}
      - {yaml_quote(workspace_volume)}
    command:
      - dagster-webserver
      - -h
      - "0.0.0.0"
      - -p
      - "3000"
      - -w
      - workspace.yaml

  dagster-daemon:
    image: {yaml_quote(images["dagster-core"])}
    container_name: {DAGSTER_DAEMON_CONTAINER}
    networks:
      - dagster_network
    environment:
{render_common_runtime_environment(6, include_docker_host=True)}
    volumes:
      - {yaml_quote(socket_volume)}
      - {yaml_quote(dagster_config_volume)}
      - {yaml_quote(workspace_volume)}
    command:
      - dagster-daemon
      - run
      - -w
      - workspace.yaml
"""


def render_common_runtime_environment(
    indent: int,
    *,
    include_docker_host: bool = False,
) -> str:
    """Render common service environment variables for compose YAML."""
    values = {
        "DAGSTER_HOME": "/opt/dagster/dagster_home/",
        "DAGSTER_POSTGRES_HOSTNAME": E2E_ENVIRONMENT["DAGSTER_POSTGRES_HOSTNAME"],
        "DAGSTER_POSTGRES_USER": E2E_ENVIRONMENT["DAGSTER_POSTGRES_USER"],
        "DAGSTER_POSTGRES_PASSWORD": E2E_ENVIRONMENT["DAGSTER_POSTGRES_PASSWORD"],
        "DAGSTER_POSTGRES_DB": E2E_ENVIRONMENT["DAGSTER_POSTGRES_DB"],
        "AWS_ENDPOINT_URL": E2E_ENVIRONMENT["AWS_ENDPOINT_URL"],
        "AWS_DEFAULT_REGION": E2E_ENVIRONMENT["AWS_DEFAULT_REGION"],
        "AWS_ACCESS_KEY_ID": E2E_ENVIRONMENT["AWS_ACCESS_KEY_ID"],
        "AWS_SECRET_ACCESS_KEY": E2E_ENVIRONMENT["AWS_SECRET_ACCESS_KEY"],
        "AWS_ALLOW_HTTP": E2E_ENVIRONMENT["AWS_ALLOW_HTTP"],
        "AWS_S3_LOCKING_PROVIDER": E2E_ENVIRONMENT["AWS_S3_LOCKING_PROVIDER"],
        "DAGSTER_FAILURE_ALERT_TOPIC_ARN": E2E_ENVIRONMENT[
            "DAGSTER_FAILURE_ALERT_TOPIC_ARN"
        ],
        "DAGSTER_FAILURE_ALERT_BASE_URL": E2E_ENVIRONMENT[
            "DAGSTER_FAILURE_ALERT_BASE_URL"
        ],
        "DEVELOPMENT_ENVIRONMENT": E2E_ENVIRONMENT["DEVELOPMENT_ENVIRONMENT"],
        "DEVELOPMENT_LOCATION": E2E_ENVIRONMENT["DEVELOPMENT_LOCATION"],
        "NAME_PREFIX": E2E_ENVIRONMENT["NAME_PREFIX"],
    }
    if include_docker_host:
        values = {"DOCKER_HOST": f"unix://{CONTAINER_SOCKET_PATH}", **values}

    prefix = " " * indent
    return "\n".join(
        f"{prefix}{key}: {yaml_quote(value)}" for key, value in values.items()
    )


def render_dagster_yaml(
    *,
