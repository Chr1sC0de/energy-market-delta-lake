        env: DAGSTER_POSTGRES_USER
      password:
        env: DAGSTER_POSTGRES_PASSWORD
      db_name:
        env: DAGSTER_POSTGRES_DB
      port: 5432
"""


def render_workspace_yaml() -> str:
    """Return the e2e Dagster workspace config."""
    return """# Generated by backend-services/scripts/aemo-etl-e2e.
load_from:
  - grpc_server:
      host: aemo-etl
      port: 4000
      location_name: "aemo-etl"
"""


def wait_for_containers_ready(
    runner: CommandRunner,
    *,
    container_names: Sequence[str],
    timeout_seconds: int,
) -> None:
    """Wait until selected e2e containers reach their ready state."""
    deadline = time.monotonic() + timeout_seconds
    last_summary = ""
    while time.monotonic() < deadline:
        states = inspect_container_states(runner, container_names)
        last_summary = summarize_container_states(states)
        failure = ready_failure(states)
        if failure is not None:
            raise CommandError(f"e2e stack failed to start: {failure}")
        if containers_are_ready(states, container_names):
            return
        time.sleep(2)

    expected = ", ".join(container_names)
    raise CommandError(f"timed out waiting for {expected}: {last_summary}")


def containers_are_ready(
    states: Mapping[str, ContainerState],
    container_names: Sequence[str],
) -> bool:
    """Return whether the selected e2e containers are ready."""
    for name in container_names:
        if name not in states:
            return False
        state = states[name]
        if name == SEED_CONTAINER:
            if state.status != "exited" or state.exit_code != 0:
                return False
            continue
        if state.status != "running":
            return False
        if name in HEALTHCHECK_CONTAINERS and state.health != "healthy":
            return False
    return True


def wait_for_ready_stack(runner: CommandRunner, *, timeout_seconds: int) -> None:
    """Wait until the e2e stack reaches its ready state."""
    deadline = time.monotonic() + timeout_seconds
    last_summary = ""
    container_names = (
        POSTGRES_CONTAINER,
        LOCALSTACK_CONTAINER,
        SEED_CONTAINER,
        AEMO_ETL_CONTAINER,
        DAGSTER_WEBSERVER_CONTAINER,
        DAGSTER_DAEMON_CONTAINER,
    )
    while time.monotonic() < deadline:
        states = inspect_container_states(runner, container_names)
        last_summary = summarize_container_states(states)
        failure = ready_failure(states)
        if failure is not None:
            raise CommandError(f"e2e stack failed to start: {failure}")
        if stack_is_ready(states):
            return
        time.sleep(2)

    raise CommandError(
        f"timed out waiting for {STACK_NAME} to become ready: {last_summary}"
    )


def drive_dagster_dataflow(
    *,
    webserver_port: int,
    timeout_seconds: int,
    expected_max_concurrent_runs: int,
    run_id: str,
    runner: CommandRunner | None = None,
    telemetry: GateRunTelemetry | None = None,
) -> dict[str, object]:
    """Start intended Dagster automation and monitor the full e2e dataflow."""
    client = DagsterGraphQLClient(dagster_graphql_url(webserver_port))
    command_runner = runner or CommandRunner()
    dataflow_telemetry = None
    if telemetry is not None:
        dataflow_telemetry = telemetry.ensure_dataflow()
    deadline = time.monotonic() + timeout_seconds
    wait_for_dagster_graphql(
        client,
        timeout_seconds=min(
            DAGSTER_GRAPHQL_READY_TIMEOUT_SECONDS,
            remaining_timeout_seconds(deadline),
        ),
    )
    started_after = time.time()
    definition_state = fetch_dagster_definition_state(client)
    validate_dagster_max_concurrent_runs(
        definition_state,
        expected_max_concurrent_runs=expected_max_concurrent_runs,
    )
    validate_dagster_automation_state(definition_state)
    start_expected_sensors(client, definition_state.selector)
    validate_dagster_automation_state(
        fetch_dagster_definition_state(client),
        expected_sensor_status="RUNNING",
    )
    bootstrap_run_ids = launch_bootstrap_runs(
        client,
        definition_state.selector,
        run_id=run_id,
    )
    monitor_started = time.monotonic()
    try:
        final_status = monitor_dagster_dataflow(
            client,
            definition_state.selector,
            started_after=started_after,
            timeout_seconds=remaining_timeout_seconds(deadline),
            runner=command_runner,
            telemetry=dataflow_telemetry,
        )
    finally:
        if telemetry is not None:
            telemetry.record_dagster_dataflow_monitor(
                monitor_started,
                time.monotonic(),
            )
    return {
        "repository_name": definition_state.selector.repository_name,
        "repository_location_name": definition_state.selector.repository_location_name,
        "started_at": datetime.fromtimestamp(
            started_after,
            timezone.utc,
        ).isoformat(),
        "bootstrap_run_ids": bootstrap_run_ids,
        "target_asset_count": final_status.target_asset_count,
        "materialized_target_assets": list(final_status.materialized_target_assets),
    }


def dagster_graphql_url(webserver_port: int) -> str:
    """Return the host URL for the e2e Dagster GraphQL endpoint."""
    return f"http://127.0.0.1:{webserver_port}/graphql"


def wait_for_dagster_graphql(
    client: DagsterGraphQLClient,
    *,
    timeout_seconds: int = DAGSTER_GRAPHQL_READY_TIMEOUT_SECONDS,
) -> None:
    """Wait until the Dagster webserver can answer GraphQL requests."""
    deadline = time.monotonic() + timeout_seconds
    last_error = "not checked"
    while time.monotonic() < deadline:
        try:
            client.execute(PING_QUERY)
            return
        except CommandError as error:
            last_error = str(error)
            time.sleep(2)
    raise CommandError(f"timed out waiting for Dagster GraphQL: {last_error}")


def execute_dagster_graphql_with_retries(
    client: DagsterGraphQLClient,
    query: str,
    variables: Mapping[str, object] | None = None,
    *,
    context: str,
    attempts: int = 3,
    timeout_seconds: int | None = None,
) -> Mapping[str, object]:
    """Execute an idempotent Dagster GraphQL request with transient retries."""
    last_error = "not attempted"
    for attempt in range(1, attempts + 1):
        try:
            if timeout_seconds is None:
                return client.execute(query, variables)
            return client.execute(
                query,
                variables,
                timeout_seconds=timeout_seconds,
            )
        except CommandError as error:
            if not is_transient_dagster_graphql_error(error):
                raise
            last_error = str(error)
            if attempt < attempts:
                time.sleep(2)
    raise CommandError(f"{context} failed after {attempts} attempts: {last_error}")


def is_transient_dagster_graphql_error(error: CommandError) -> bool:
    """Return whether a GraphQL failure came from the local transport."""
    return str(error).startswith("Dagster GraphQL request failed at ")


def fetch_dagster_definition_state(
    client: DagsterGraphQLClient,
) -> DagsterDefinitionState:
    """Fetch the e2e Dagster repository, sensor, schedule, and run queue state."""
    data = execute_dagster_graphql_with_retries(
        client,
        DAGSTER_DEFINITION_STATE_QUERY,
        context="fetch Dagster definition state",
    )
    instance = data.get("instance")
    if not isinstance(instance, Mapping):
        raise CommandError("Dagster GraphQL did not return instance state")
    run_queue_config = instance.get("runQueueConfig")
    if not isinstance(run_queue_config, Mapping):
        raise CommandError("Dagster GraphQL did not return run queue config")
    max_concurrent_runs = run_queue_config.get("maxConcurrentRuns")
    if not isinstance(max_concurrent_runs, int):
        raise CommandError("Dagster maxConcurrentRuns was not an integer")

    repositories = require_graphql_typename(
        data.get("repositoriesOrError"),
        expected_typename="RepositoryConnection",
        context="repositoriesOrError",
    )
    nodes = repositories.get("nodes")
    if not isinstance(nodes, list):
        raise CommandError("Dagster repositoriesOrError.nodes was not a list")
    repository = select_e2e_repository(nodes)
    selector = DagsterRepositorySelector(
        repository_name=expect_str(repository.get("name"), "repository name"),
        repository_location_name=expect_str(
            expect_mapping(repository.get("location"), "repository location").get(
                "name"
            ),
            "repository location name",
        ),
    )

    return DagsterDefinitionState(
        selector=selector,
        max_concurrent_runs=max_concurrent_runs,
        sensors=read_instigator_statuses(repository, key="sensors"),
        schedules=read_instigator_statuses(repository, key="schedules"),
    )


def select_e2e_repository(nodes: Sequence[object]) -> Mapping[str, object]:
    """Return the single e2e repository from a Dagster repositories payload."""
    repositories = [node for node in nodes if isinstance(node, Mapping)]
    matching = [
        repository
        for repository in repositories
        if expect_mapping(repository.get("location"), "repository location").get("name")
        == DAGSTER_REPOSITORY_LOCATION_NAME
    ]
    if len(matching) == 1:
        return matching[0]
    if len(repositories) == 1:
        return repositories[0]
    names = [
        f"{repository_location_name(repository)}/{repository.get('name')}"
        for repository in repositories
    ]
    raise CommandError(
        "expected exactly one Dagster repository for the e2e stack, found "
        f"{len(repositories)}: {', '.join(names)}"
    )


def repository_location_name(repository: Mapping[str, object]) -> object:
    """Return a repository location name from a GraphQL repository payload."""
    location = repository.get("location")
    if not isinstance(location, Mapping):
        return "<unknown>"
    return location.get("name", "<unknown>")


def read_instigator_statuses(
    repository: Mapping[str, object],
    *,
    key: str,
) -> dict[str, str]:
    """Return sensor or schedule statuses from a repository payload."""
    instigators = repository.get(key)
    if not isinstance(instigators, list):
        raise CommandError(f"Dagster repository {key} was not a list")
    statuses: dict[str, str] = {}
    for instigator in instigators:
        if not isinstance(instigator, Mapping):
            continue
        state = expect_mapping(instigator.get(f"{key[:-1]}State"), f"{key} state")
        statuses[expect_str(instigator.get("name"), f"{key} name")] = expect_str(
            state.get("status"), f"{key} status"
        )
    return statuses


def validate_dagster_max_concurrent_runs(
    definition_state: DagsterDefinitionState,
    *,
    expected_max_concurrent_runs: int,
) -> None:
    """Fail if Dagster did not load the requested queued run concurrency."""
    if definition_state.max_concurrent_runs != expected_max_concurrent_runs:
        raise CommandError(
            "Dagster max_concurrent_runs is "
            f"{definition_state.max_concurrent_runs}, expected "
            f"{expected_max_concurrent_runs}"
        )


def validate_dagster_automation_state(
    definition_state: DagsterDefinitionState,
    *,
    expected_sensor_status: str = "STOPPED",
) -> None:
    """Validate intended and protected Dagster automation states."""
    expected_sensors = set(EXPECTED_DATAFLOW_SENSOR_NAMES)
    missing_sensors = sorted(expected_sensors - set(definition_state.sensors))
    if missing_sensors:
        raise CommandError(
            "expected e2e dataflow sensors are missing: " + ", ".join(missing_sensors)
        )

    expected_not_ready = sorted(
        name
        for name in expected_sensors
        if definition_state.sensors[name] != expected_sensor_status
    )
    if expected_not_ready:
        raise CommandError(
            "expected e2e dataflow sensors are not "
            f"{expected_sensor_status}: "
            + ", ".join(
                f"{name}={definition_state.sensors[name]}"
                for name in expected_not_ready
            )
        )

    unexpected_running_sensors = sorted(
        name
        for name, status in definition_state.sensors.items()
        if name not in expected_sensors and status == "RUNNING"
    )
    if unexpected_running_sensors:
        raise CommandError(
            "unexpected Dagster sensors are running: "
            + ", ".join(unexpected_running_sensors)
        )

    missing_schedules = sorted(
        set(PROTECTED_STOPPED_SCHEDULE_NAMES) - set(definition_state.schedules)
    )
    if missing_schedules:
        raise CommandError(
            "expected protected Dagster schedules are missing: "
            + ", ".join(missing_schedules)
        )

    running_schedules = sorted(
        name
        for name, status in definition_state.schedules.items()
        if status == "RUNNING"
    )
    if running_schedules:
        raise CommandError(
            "protected Dagster schedules are running: " + ", ".join(running_schedules)
        )


def start_expected_sensors(
    client: DagsterGraphQLClient,
    selector: DagsterRepositorySelector,
) -> None:
    """Start only the sensors required for the e2e dataflow."""
    for sensor_name in EXPECTED_DATAFLOW_SENSOR_NAMES:
        payload = execute_dagster_graphql_with_retries(
            client,
            START_SENSOR_MUTATION,
            {
                "selector": {
                    **selector.to_graphql(),
                    "sensorName": sensor_name,
                }
            },
            context=f"start sensor {sensor_name}",
        )
        result = require_graphql_typename(
            payload.get("startSensor"),
            expected_typename="Sensor",
            context=f"startSensor({sensor_name})",
        )
        sensor_state = expect_mapping(
            result.get("sensorState"),
            f"started sensor state for {sensor_name}",
        )
        status = expect_str(
            sensor_state.get("status"),
            f"started sensor status for {sensor_name}",
        )
        if status != "RUNNING":
            raise CommandError(f"{sensor_name} started with status {status}")


def launch_bootstrap_runs(
    client: DagsterGraphQLClient,
    selector: DagsterRepositorySelector,
    *,
    run_id: str,
) -> list[str]:
    """Bootstrap non-sensor materializations required by the gas_model target."""
    run_ids: list[str] = []
    for job_name in BOOTSTRAP_JOB_NAMES:
        run_ids.append(
            launch_dagster_run(
                client,
                selector,
                pipeline_name=job_name,
                run_id=run_id,
            )
        )
    if BOOTSTRAP_ASSET_KEYS:
        run_ids.append(
            launch_dagster_run(
                client,
                selector,
                pipeline_name=IMPLICIT_ASSET_JOB_NAME,
                run_id=run_id,
                asset_keys=BOOTSTRAP_ASSET_KEYS,
            )
        )
    return run_ids


def launch_dagster_run(
    client: DagsterGraphQLClient,
    selector: DagsterRepositorySelector,
    *,
    pipeline_name: str,
    run_id: str,
    asset_keys: Sequence[Sequence[str]] = (),
) -> str:
    """Launch one Dagster run and return its run ID."""
    graphql_selector: dict[str, object] = {
        **selector.to_graphql(),
        "pipelineName": pipeline_name,
    }
    if asset_keys:
        graphql_selector["assetSelection"] = [
            {"path": list(asset_key)} for asset_key in asset_keys
        ]
    payload = client.execute(
        LAUNCH_RUN_MUTATION,
        {
            "executionParams": {
                "selector": graphql_selector,
                "runConfigData": {},
                "executionMetadata": {
                    "tags": [{"key": E2E_RUN_TAG, "value": run_id}],
                },
            }
        },
    )
    result = require_graphql_typename(
        payload.get("launchRun"),
        expected_typename="LaunchRunSuccess",
        context=f"launchRun({pipeline_name})",
    )
    run = expect_mapping(result.get("run"), f"launched run for {pipeline_name}")
    return expect_str(run.get("runId"), f"run ID for {pipeline_name}")


def monitor_dagster_dataflow(
    client: DagsterGraphQLClient,
    selector: DagsterRepositorySelector,
    *,
    started_after: float,
    timeout_seconds: int,
    runner: CommandRunner | None = None,
    poll_interval_seconds: int = DEFAULT_DAGSTER_POLL_INTERVAL_SECONDS,
    telemetry: DagsterDataflowTelemetry | None = None,
) -> DagsterDataflowStatus:
    """Poll Dagster until the gas_model target succeeds, fails, or times out."""
    deadline = time.monotonic() + timeout_seconds
    command_runner = runner or CommandRunner()
    last_summary = "Dagster dataflow has not been checked yet"
    while time.monotonic() < deadline:
        status = fetch_dagster_dataflow_status(
            client,
            selector,
            started_after=started_after,
            runner=command_runner,
        )
        if telemetry is not None:
            telemetry.record_status_sample(status)
        last_summary = summarize_dagster_dataflow_status(status)
        sys.stdout.write(f"{last_summary}\n")
        sys.stdout.flush()
        fail_fast_summary = dagster_dataflow_failure_summary(status)
        if fail_fast_summary is not None:
            raise CommandError(f"Dagster dataflow failed: {fail_fast_summary}")
        if status.is_successful:
            return status
        time.sleep(poll_interval_seconds)

    raise CommandError(f"timed out waiting for Dagster dataflow: {last_summary}")


def fetch_dagster_dataflow_status(
    client: DagsterGraphQLClient,
    selector: DagsterRepositorySelector,
    *,
    started_after: float,
    runner: CommandRunner | None = None,
) -> DagsterDataflowStatus:
    """Fetch and normalize the current Dagster dataflow monitor state."""
    run_data = execute_dagster_graphql_with_retries(
        client,
        DAGSTER_DATAFLOW_RUN_STATUS_QUERY,
        {
            "createdAfter": started_after,
            "activeStatuses": list(ACTIVE_RUN_STATUSES),
            "failedStatuses": list(FAILED_RUN_STATUSES),
        },
        context="fetch Dagster run status",
        timeout_seconds=DAGSTER_DATAFLOW_STATUS_TIMEOUT_SECONDS,
    )
    active_runs = read_runs(run_data.get("activeRuns"), context="activeRuns")
    failed_runs = read_runs(run_data.get("failedRuns"), context="failedRuns")
    all_runs = read_runs(run_data.get("allRuns"), context="allRuns")

    target_data = execute_dagster_graphql_with_retries(
        client,
        DAGSTER_DATAFLOW_TARGET_STATUS_QUERY,
        {
            **selector.to_graphql(),
            "startedAfterMillis": str(int(started_after * 1000)),
        },
        context="fetch Dagster target status",
        timeout_seconds=DAGSTER_DATAFLOW_STATUS_TIMEOUT_SECONDS,
    )
    target_assets = target_data.get("targetAssets")
    if not isinstance(target_assets, list):
        raise CommandError("Dagster targetAssets was not a list")
    target_asset_events = read_assets_or_error(
        target_data.get("targetAssetEvents"),
        context="targetAssetEvents",
    )
    status = evaluate_dagster_dataflow_status(
        active_runs=active_runs,
        failed_runs=failed_runs,
        all_runs=all_runs,
        target_assets=target_assets,
        target_asset_events=target_asset_events,
        checked_assets=(),
        started_after=started_after,
    )
    if (
        status.failed_runs
        or status.failed_target_assets
        or status.missing_target_assets
    ):
        return status

    failed_asset_check_labels = fetch_failed_asset_checks_from_postgres(
        runner or CommandRunner(),
        started_after=started_after,
    )
    return evaluate_dagster_dataflow_status(
        active_runs=active_runs,
        failed_runs=failed_runs,
        all_runs=all_runs,
        target_assets=target_assets,
        target_asset_events=target_asset_events,
        checked_assets=(),
        started_after=started_after,
        failed_asset_check_labels=failed_asset_check_labels,
    )


def evaluate_dagster_dataflow_status(
    *,
    active_runs: Sequence[Mapping[str, object]],
    failed_runs: Sequence[Mapping[str, object]],
    all_runs: Sequence[Mapping[str, object]] | None = None,
    target_assets: Sequence[object],
    target_asset_events: Sequence[object],
    checked_assets: Sequence[object],
    started_after: float,
    failed_asset_check_labels: Sequence[str] = (),
) -> DagsterDataflowStatus:
    """Evaluate raw Dagster GraphQL status payloads."""
    materialized_target_assets: list[str] = []
    missing_target_assets: list[str] = []
    failed_target_assets: list[str] = []
    missing_asset_checks: list[str] = []
    failed_asset_checks: list[str] = list(failed_asset_check_labels)
    target_asset_keys: set[str] = set()
    target_materialization_timestamps: list[float] = []

    for asset in target_assets:
        if not isinstance(asset, Mapping):
            continue
        asset_key = read_asset_key(asset)
        if asset.get("isMaterializable") is False:
            continue
        target_asset_keys.add(asset_key)
        latest_materialization = latest_event_after(
            asset.get("assetMaterializations"),
            started_after=started_after,
        )
        if latest_materialization is None:
            missing_target_assets.append(asset_key)
        else:
            materialized_target_assets.append(asset_key)
            target_materialization_timestamps.append(
                event_timestamp_seconds(latest_materialization.get("timestamp"))
            )

        if latest_materialization is not None:
            read_asset_check_status(
                asset=asset,
                asset_key=asset_key,
                started_after=started_after,
                latest_materialization=latest_materialization,
                missing_asset_checks=missing_asset_checks,
                failed_asset_checks=failed_asset_checks,
            )

    for asset in target_asset_events:
        if not isinstance(asset, Mapping):
            continue
        asset_key = read_asset_key(asset, key_name="key")
        if asset_key not in target_asset_keys:
            continue
        latest_failure = latest_failed_materialization_after(
            asset.get("assetEventHistory"),
            started_after=started_after,
        )
        if latest_failure is not None:
            failed_target_assets.append(
                f"{asset_key} ({latest_failure.get('message', 'failed')})"
            )

    for asset in checked_assets:
        if not isinstance(asset, Mapping):
            continue
        read_any_failed_asset_checks_after(
            asset=asset,
            started_after=started_after,
            failed_asset_checks=failed_asset_checks,
        )

    return DagsterDataflowStatus(
        active_runs=tuple(sorted(format_run(run) for run in active_runs)),
        failed_runs=tuple(sorted(format_run(run) for run in failed_runs)),
        materialized_target_assets=tuple(sorted(set(materialized_target_assets))),
        missing_target_assets=tuple(sorted(set(missing_target_assets))),
        failed_target_assets=tuple(sorted(set(failed_target_assets))),
        missing_asset_checks=tuple(sorted(set(missing_asset_checks))),
        failed_asset_checks=tuple(sorted(set(failed_asset_checks))),
        run_status_counts=count_run_statuses(
            [*active_runs, *failed_runs] if all_runs is None else all_runs
        ),
        target_materialization_timestamps=tuple(
            sorted(set(target_materialization_timestamps))
        ),
    )


def count_run_statuses(runs: Sequence[Mapping[str, object]]) -> dict[str, int]:
    """Return Dagster run status counts from raw run payloads."""
    counts: dict[str, int] = {}
    for run in runs:
        status = run.get("status")
        if not isinstance(status, str):
            continue
        counts[status] = counts.get(status, 0) + 1
    return dict(sorted(counts.items()))


def read_asset_check_status(
    *,
    asset: Mapping[str, object],
    asset_key: str,
    started_after: float,
    latest_materialization: Mapping[str, object],
    missing_asset_checks: list[str],
    failed_asset_checks: list[str],
) -> None:
    """Read target asset check status into missing and failed lists."""
    checks = read_asset_checks(asset, asset_key=asset_key)
    materialization_run_id = latest_materialization.get("runId")
    materialization_timestamp = event_timestamp_seconds(
        latest_materialization.get("timestamp")
    )
    for check in checks:
        check_name = expect_str(check.get("name"), f"check name for {asset_key}")
        execution = check.get("executionForLatestMaterialization")
        check_label = f"{asset_key}:{check_name}"
        if not isinstance(execution, Mapping):
            missing_asset_checks.append(check_label)
            continue
        execution_timestamp = event_timestamp_seconds(execution.get("timestamp"))
        if execution_timestamp < started_after:
            missing_asset_checks.append(check_label)
            continue
        evaluation = execution.get("evaluation")
        if not isinstance(evaluation, Mapping):
            failed_asset_checks.append(f"{check_label}=missing_evaluation")
            continue
        target_materialization = evaluation.get("targetMaterialization")
        if isinstance(target_materialization, Mapping):
            target_run_id = target_materialization.get("runId")
            if target_run_id is not None and target_run_id != materialization_run_id:
                missing_asset_checks.append(check_label)
                continue
            target_timestamp = event_timestamp_seconds(
                target_materialization.get("timestamp")
            )
            if target_timestamp < materialization_timestamp:
                missing_asset_checks.append(check_label)
                continue
        append_failed_check_if_needed(
            failed_asset_checks,
            check_label=check_label,
            execution=execution,
            evaluation=evaluation,
        )


def read_any_failed_asset_checks_after(
    *,
    asset: Mapping[str, object],
    started_after: float,
    failed_asset_checks: list[str],
) -> None:
    """Capture failed asset checks from any e2e run, including WARN checks."""
    asset_key = read_asset_key(asset)
    for check in read_asset_checks(asset, asset_key=asset_key):
        execution = check.get("executionForLatestMaterialization")
        if not isinstance(execution, Mapping):
            continue
        if event_timestamp_seconds(execution.get("timestamp")) < started_after:
            continue
        evaluation = execution.get("evaluation")
        if not isinstance(evaluation, Mapping):
            continue
        append_failed_check_if_needed(
            failed_asset_checks,
            check_label=f"{asset_key}:{check.get('name', '<unknown>')}",
            execution=execution,
            evaluation=evaluation,
        )


def append_failed_check_if_needed(
    failed_asset_checks: list[str],
    *,
    check_label: str,
    execution: Mapping[str, object],
    evaluation: Mapping[str, object],
) -> None:
    """Append a failed check label when execution or evaluation failed."""
    status = execution.get("status")
    success = evaluation.get("success")
    severity = evaluation.get("severity")
    if status in FAILED_CHECK_STATUSES or success is False:
        failed_asset_checks.append(f"{check_label}={status}/{severity}")


def fetch_failed_asset_checks_from_postgres(
    runner: CommandRunner,
    *,
    started_after: float,
) -> tuple[str, ...]:
    """Read failed e2e asset checks directly from Dagster event-log storage."""
    query = failed_asset_checks_sql(started_after)
    try:
        result = runner.run(
            [
                "podman",
                "exec",
                POSTGRES_CONTAINER,
                "psql",
                "-X",
                "-q",
                "-t",
                "-A",
                "-v",
                "ON_ERROR_STOP=1",
                "-U",
                E2E_ENVIRONMENT["DAGSTER_POSTGRES_USER"],
                "-d",
                E2E_ENVIRONMENT["DAGSTER_POSTGRES_DB"],
                "-c",
                query,
            ],
            capture_output=True,
        )
    except subprocess.CalledProcessError as error:
        detail = (error.stderr or error.stdout or str(error)).strip()
        raise CommandError(f"fetch Dagster asset check status failed: {detail}") from error

    payload_text = result.stdout.strip()
    if payload_text == "":
        payload_text = "[]"
    payload = json.loads(payload_text)
    if not isinstance(payload, list):
        raise CommandError("Dagster asset check status query did not return a list")
    return tuple(
        sorted(
            format_failed_asset_check_row(row)
            for row in payload
            if isinstance(row, Mapping)
        )
    )


def failed_asset_checks_sql(started_after: float) -> str:
    """Return the Dagster Postgres query for failed asset checks in this run."""
    started_at = datetime.fromtimestamp(started_after, timezone.utc).replace(
        tzinfo=None
    )
    started_at_sql = started_at.isoformat(sep=" ", timespec="microseconds")
    return f"""
with latest_check_executions as (
  select
    asset_key,
    check_name,
    execution_status,
    evaluation_event,
    coalesce(evaluation_event_timestamp, create_timestamp) as sort_timestamp,
    row_number() over (
      partition by asset_key, check_name
      order by coalesce(evaluation_event_timestamp, create_timestamp) desc, run_id desc
    ) as latest_rank
  from asset_check_executions
  where coalesce(evaluation_event_timestamp, create_timestamp)
    >= timestamp '{started_at_sql}'
)
select coalesce(
  json_agg(
    json_build_object(
      'asset_key', asset_key,
      'check_name', check_name,
      'execution_status', execution_status,
      'evaluation_event', evaluation_event::json
    )
    order by sort_timestamp, asset_key, check_name
  ),
  '[]'::json
)
from latest_check_executions
where latest_rank = 1
  and evaluation_event is not null
  and (
    execution_status in ('FAILED', 'EXECUTION_FAILED', 'SKIPPED')
    or coalesce(
      evaluation_event::json #>> '{{dagster_event,event_specific_data,success}}',
      'true'
    ) = 'false'
  );
"""


def format_failed_asset_check_row(row: Mapping[str, object]) -> str:
    """Return a compact failed-check label from one Dagster DB row."""
    asset_key = format_postgres_asset_key(row.get("asset_key"))
    check_name = expect_str(row.get("check_name"), "asset check name")
    execution_status = expect_str(
        row.get("execution_status"),
        f"execution status for {asset_key}:{check_name}",
    )
    severity = read_asset_check_severity(row.get("evaluation_event"))
    return f"{asset_key}:{check_name}={execution_status}/{severity}"


def format_postgres_asset_key(value: object) -> str:
    """Return a slash-separated asset key from Dagster's stored JSON text."""
    if isinstance(value, list) and all(isinstance(part, str) for part in value):
        return "/".join(value)
    if isinstance(value, str):
        try:
            parsed = json.loads(value)
        except json.JSONDecodeError:
            return value
        if isinstance(parsed, list) and all(isinstance(part, str) for part in parsed):
            return "/".join(parsed)
        return value
    raise CommandError("expected asset check asset key to be a string or list")


def read_asset_check_severity(evaluation_event: object) -> str:
    """Return the failed asset check severity stored in a Dagster event payload."""
    if not isinstance(evaluation_event, Mapping):
        return "<unknown>"
    dagster_event = evaluation_event.get("dagster_event")
    if not isinstance(dagster_event, Mapping):
        return "<unknown>"
    event_data = dagster_event.get("event_specific_data")
    if not isinstance(event_data, Mapping):
        return "<unknown>"
    severity = event_data.get("severity")
    if isinstance(severity, str):
        return severity.rsplit(".", maxsplit=1)[-1]
    if isinstance(severity, Mapping):
        enum_value = severity.get("__enum__")
        if isinstance(enum_value, str):
            return enum_value.rsplit(".", maxsplit=1)[-1]
    return "<unknown>"


def read_asset_checks(
    asset: Mapping[str, object],
    *,
    asset_key: str,
) -> tuple[Mapping[str, object], ...]:
    """Read asset checks from an asset node GraphQL payload."""
    checks_or_error = asset.get("assetChecksOrError")
    if not isinstance(checks_or_error, Mapping):
        return ()
    typename = checks_or_error.get("__typename")
    if typename != "AssetChecks":
        if typename not in {None, "AssetCheckNeedsMigrationError"}:
            message = checks_or_error.get("message", typename)
            raise CommandError(
                f"could not read asset checks for {asset_key}: {message}"
            )
        return ()
    checks = checks_or_error.get("checks")
    if not isinstance(checks, list):
        return ()
    return tuple(check for check in checks if isinstance(check, Mapping))


def latest_event_after(
    events: object,
    *,
    started_after: float,
) -> Mapping[str, object] | None:
    """Return the first event if it happened after the e2e monitor start."""
    if not isinstance(events, list) or len(events) == 0:
        return None
    event = events[0]
    if not isinstance(event, Mapping):
        return None
    if event_timestamp_seconds(event.get("timestamp")) < started_after:
        return None
    return event


def latest_failed_materialization_after(
    event_history: object,
    *,
    started_after: float,
) -> Mapping[str, object] | None:
    """Return the latest failed materialization event after monitor start."""
    if not isinstance(event_history, Mapping):
        return None
    results = event_history.get("results")
    if not isinstance(results, list) or len(results) == 0:
        return None
    event = results[0]
    if not isinstance(event, Mapping):
        return None
    if event.get("__typename") != "FailedToMaterializeEvent":
        return None
    if event_timestamp_seconds(event.get("timestamp")) < started_after:
        return None
    return event


def read_runs(
    payload: object,
    *,
    context: str,
) -> tuple[Mapping[str, object], ...]:
    """Read a Dagster RunsOrError payload."""
    runs = require_graphql_typename(payload, expected_typename="Runs", context=context)
    results = runs.get("results")
    if not isinstance(results, list):
        raise CommandError(f"Dagster {context}.results was not a list")
    return tuple(run for run in results if isinstance(run, Mapping))


def read_assets_or_error(
    payload: object,
    *,
    context: str,
) -> tuple[Mapping[str, object], ...]:
    """Read a Dagster AssetsOrError payload."""
    assets = require_graphql_typename(
        payload,
        expected_typename="AssetConnection",
        context=context,
    )
    nodes = assets.get("nodes")
    if not isinstance(nodes, list):
        raise CommandError(f"Dagster {context}.nodes was not a list")
    return tuple(node for node in nodes if isinstance(node, Mapping))


def read_asset_key(asset: Mapping[str, object], *, key_name: str = "assetKey") -> str:
    """Return a slash-separated asset key from an asset node payload."""
    asset_key = expect_mapping(asset.get(key_name), "asset key")
    path = asset_key.get("path")
    if not isinstance(path, list) or not all(isinstance(part, str) for part in path):
        raise CommandError("Dagster asset key path was not a string list")
    return "/".join(path)


def event_timestamp_seconds(value: object) -> float:
    """Return a Dagster event timestamp as seconds since epoch."""
    if value is None:
        return 0.0
    timestamp = float(value)
    if timestamp > 10_000_000_000:
        return timestamp / 1000
    return timestamp


def dagster_dataflow_failure_summary(
    status: DagsterDataflowStatus,
) -> str | None:
    """Return an immediate dataflow failure summary, when one exists."""
    if status.failed_runs:
        return "failed runs: " + ", ".join(status.failed_runs[:10])
    if status.failed_target_assets:
        return "failed target materializations: " + ", ".join(
            status.failed_target_assets[:10]
        )
    if status.failed_asset_checks:
        if status.active_runs:
            return None
        return "failed asset checks: " + ", ".join(status.failed_asset_checks[:10])
    return None


def summarize_dagster_dataflow_status(status: DagsterDataflowStatus) -> str:
    """Return a compact monitor status line."""
    return (
        "Dagster dataflow: "
        f"{len(status.materialized_target_assets)}/{status.target_asset_count} "
        "target assets materialized; "
        f"{len(status.active_runs)} active runs; "
        f"{len(status.missing_asset_checks)} missing target checks; "
        f"{len(status.failed_asset_checks)} failed checks"
    )


def format_run(run: Mapping[str, object]) -> str:
    """Return a compact run label."""
    return (
        f"{run.get('runId', '<unknown>')}"
        f"({run.get('jobName', '<unknown>')}={run.get('status', '<unknown>')})"
    )


def require_graphql_typename(
    value: object,
    *,
    expected_typename: str,
    context: str,
) -> Mapping[str, object]:
    """Return a GraphQL object, failing on error union members."""
    mapping = expect_mapping(value, context)
    typename = mapping.get("__typename")
    if typename == expected_typename:
        return mapping
    message = mapping.get("message", mapping)
    raise CommandError(
        f"Dagster GraphQL {context} returned {typename}, expected "
        f"{expected_typename}: {message}"
    )


def expect_mapping(value: object, context: str) -> Mapping[str, object]:
    """Return a mapping or fail with a user-actionable error."""
    if not isinstance(value, Mapping):
        raise CommandError(f"expected {context} to be an object")
    return value


def expect_str(value: object, context: str) -> str:
    """Return a string or fail with a user-actionable error."""
    if not isinstance(value, str):
        raise CommandError(f"expected {context} to be a string")
    return value


def inspect_container_states(
    runner: CommandRunner,
    container_names: Sequence[str],
) -> dict[str, ContainerState]:
    """Inspect Podman containers and return normalized states."""
    states: dict[str, ContainerState] = {}
    for name in container_names:
        result = runner.run(
            ["podman", "inspect", name],
            capture_output=True,
            check=False,
        )
        if result.returncode != 0:
            continue
        payload = json.loads(result.stdout)
        if len(payload) == 0:
            continue
        raw_state = payload[0].get("State", {})
        health = raw_state.get("Health", {}).get("Status")
        states[name] = ContainerState(
            name=name,
            status=str(raw_state.get("Status", "unknown")),
            exit_code=raw_state.get("ExitCode"),
            health=str(health) if health is not None else None,
        )
    return states


def stack_is_ready(states: Mapping[str, ContainerState]) -> bool:
    """Return whether every required e2e service reached ready state."""
    if SEED_CONTAINER not in states:
        return False
    seed_state = states[SEED_CONTAINER]
    if seed_state.status != "exited" or seed_state.exit_code != 0:
        return False

    for name in LONG_RUNNING_CONTAINERS:
        if name not in states:
            return False
        state = states[name]
        if state.status != "running":
            return False
        if name in HEALTHCHECK_CONTAINERS and state.health != "healthy":
            return False
    return True


def ready_failure(states: Mapping[str, ContainerState]) -> str | None:
    """Return a startup failure summary when a container is irrecoverably failed."""
    seed_state = states.get(SEED_CONTAINER)
    if (
        seed_state is not None
        and seed_state.status == "exited"
        and seed_state.exit_code != 0
    ):
        return f"{SEED_CONTAINER} exited with {seed_state.exit_code}"

    for name in LONG_RUNNING_CONTAINERS:
        state = states.get(name)
        if state is None:
            continue
        if state.status in {"dead", "exited"}:
            return f"{name} is {state.status} with exit code {state.exit_code}"
        if name in HEALTHCHECK_CONTAINERS and state.health == "unhealthy":
            return f"{name} is unhealthy"
    return None


def summarize_container_states(states: Mapping[str, ContainerState]) -> str:
    """Return a compact human-readable container state summary."""
    if len(states) == 0:
        return "no e2e containers have been created"
    return ", ".join(
        f"{name}={state.status}"
        + (f"/{state.health}" if state.health is not None else "")
        for name, state in sorted(states.items())
    )


def collect_logs(
    runner: CommandRunner,
    compose_command: Sequence[str],
    logs_dir: Path,
    cwd: Path,
) -> None:
    """Collect service logs into the run directory."""
    logs_dir.mkdir(parents=True, exist_ok=True)
    for service_name in SERVICE_NAMES:
        result = runner.run(
            [*compose_command, "logs", service_name],
            cwd=cwd,
            capture_output=True,
            check=False,
        )
        log_text = result.stdout
        if result.stderr:
            log_text = f"{log_text}\n[stderr]\n{result.stderr}"
        (logs_dir / f"{service_name}.log").write_text(log_text, encoding="utf-8")


def cleanup_stack(
    runner: CommandRunner,
    compose_command: Sequence[str],
    *,
    phase: str = "cleanup",
) -> list[dict[str, object]]:
    """Remove e2e stack containers, worker containers, and named volumes."""
    issues: list[dict[str, object]] = []
    issues.extend(cleanup_dagster_run_worker_containers(runner, phase=phase))
    compose_down_command = [*compose_command, "down", "-v", "--remove-orphans"]
    compose_down_result = runner.run(
        compose_down_command,
        capture_output=True,
        check=False,
    )
    echo_cleanup_output(compose_down_result, command=compose_down_command, phase=phase)
    record_cleanup_issue(
        issues,
        compose_down_command,
        compose_down_result,
        phase=phase,
    )
    issues.extend(cleanup_dagster_run_worker_containers(runner, phase=phase))
    network_rm_command = ["podman", "network", "rm", NETWORK_NAME]
    network_rm_result = runner.run(
        network_rm_command,
        capture_output=True,
        check=False,
    )
    echo_cleanup_output(network_rm_result, command=network_rm_command, phase=phase)
    record_cleanup_issue(issues, network_rm_command, network_rm_result, phase=phase)
    return issues


def cleanup_stack_with_telemetry(
    runner: CommandRunner,
    compose_command: Sequence[str],
    *,
    telemetry: GateRunTelemetry,
    phase: str,
) -> list[dict[str, object]]:
    """Remove e2e resources and record cleanup timing."""
    started = time.monotonic()
    issues: list[dict[str, object]] = []
    try:
        issues = cleanup_stack(runner, compose_command, phase=phase)
        return issues
    finally:
        telemetry.record_cleanup(
            phase,
            started,
            time.monotonic(),
            issues=issues,
        )


def cleanup_dagster_run_worker_containers(
    runner: CommandRunner,
    *,
    phase: str,
) -> list[dict[str, object]]:
    """Remove Dagster run workers launched outside the compose project."""
    issues: list[dict[str, object]] = []
    ps_command = [
        "podman",
        "ps",
        "-aq",
        "--filter",
        f"network={NETWORK_NAME}",
        "--filter",
        "label=dagster/run_id",
    ]
    result = runner.run(
        ps_command,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        record_cleanup_issue(issues, ps_command, result, phase=phase)
        return issues
    container_ids = tuple(
        line.strip() for line in result.stdout.splitlines() if line.strip()
    )
    if len(container_ids) == 0:
        return issues
    rm_command = ["podman", "rm", "-f", *container_ids]
    rm_result = runner.run(
        rm_command,
        capture_output=True,
        check=False,
    )
    echo_cleanup_output(rm_result, command=rm_command, phase=phase)
    record_cleanup_issue(issues, rm_command, rm_result, phase=phase)
    return issues


def echo_cleanup_output(
    result: subprocess.CompletedProcess[str],
    *,
    command: Sequence[str],
    phase: str,
) -> None:
    """Preserve cleanup command output after capturing it for the manifest."""
    stderr = result.stderr.strip() if result.stderr else ""
    if is_benign_pre_run_cleanup_issue(command, result, stderr, phase=phase):
        return
    if result.stdout:
        sys.stdout.write(result.stdout)
    if result.stderr:
        sys.stderr.write(result.stderr)


def record_cleanup_issue(
    issues: list[dict[str, object]],
    command: Sequence[str],
    result: subprocess.CompletedProcess[str],
    *,
    phase: str,
) -> None:
    """Append a cleanup warning or failure for manifest evidence."""
    stdout = result.stdout.strip() if result.stdout else ""
    stderr = result.stderr.strip() if result.stderr else ""
    if result.returncode == 0 and len(stderr) == 0:
        return
    if is_benign_pre_run_cleanup_issue(command, result, stderr, phase=phase):
        return
    severity = "error" if result.returncode != 0 else "warning"
    issue: dict[str, object] = {
        "severity": severity,
        "command": list(command),
        "returncode": result.returncode,
    }
    if len(stdout) > 0:
        issue["stdout"] = stdout
    if len(stderr) > 0:
        issue["stderr"] = stderr
    issues.append(issue)
    sys.stderr.write(
        f"{STACK_NAME} cleanup {severity}: {' '.join(command)} "
        f"returned {result.returncode}\n"
    )


def is_benign_pre_run_cleanup_issue(
    command: Sequence[str],
    result: subprocess.CompletedProcess[str],
    stderr: str,
    *,
    phase: str,
) -> bool:
    """Return whether pre-run cleanup only found already-absent resources."""
    if phase != "pre-run":
        return False
    stderr_lines = tuple(line.strip() for line in stderr.splitlines() if line.strip())
    if len(stderr_lines) == 0:
        return False
    if command[:3] == ["podman", "network", "rm"]:
        return result.returncode == 1 and all(
            "network not found" in line or "unable to find network" in line
            for line in stderr_lines
        )
    if command[-3:] == ["down", "-v", "--remove-orphans"]:
        return result.returncode == 0 and all(
            "no container with name or ID" in line
            or "no container with ID or name" in line
            or "no pod with name or ID" in line
            for line in stderr_lines
        )
    return False


def cleanup_has_errors(issues: Sequence[Mapping[str, object]]) -> bool:
    """Return whether cleanup captured at least one failed command."""
    return any(issue.get("severity") == "error" for issue in issues)


def cleanup_manifest_status(
    *,
    base_status: str,
    warning_status: str,
    error_status: str,
    issues: Sequence[Mapping[str, object]],
) -> str:
    """Return the manifest cleanup status for captured cleanup issues."""
    if cleanup_has_errors(issues):
        return error_status
    if len(issues) > 0:
        return warning_status
    return base_status

def base_manifest(
    *,
    run_id: str,
    run_dir: Path,
    compose_file: Path,
    dagster_config_file: Path,
    workspace_file: Path,
    podman_socket: Path,
    image_specs: Sequence[ImageSpec],
    options: RunOptions,
) -> dict[str, object]:
    """Return the initial run manifest payload."""
    return {
        "run_id": run_id,
        "stack_name": STACK_NAME,
        "network_name": NETWORK_NAME,
        "status": "running",
        "started_at": now_iso(),
        "completed_at": None,
        "cleanup": "pending",
        "run_dir": str(run_dir),
        "compose_file": str(compose_file),
        "dagster_config_file": str(dagster_config_file),
        "workspace_file": str(workspace_file),
        "podman_socket": str(podman_socket),
        "images": {spec.name: spec.tag for spec in image_specs},
        "options": {
            "rebuild": options.rebuild,
            "reuse": options.reuse,
            "always_clean": options.always_clean,
            "scenario": options.scenario,
            "seed_root": str(options.seed_root) if options.seed_root is not None else None,
            "webserver_port": options.webserver_port,
            "raw_latest_count": options.raw_latest_count,
            "zip_latest_count": options.zip_latest_count,
            "timeout_seconds": options.timeout_seconds,
            "max_concurrent_runs": options.max_concurrent_runs,
        },
    }


def now_iso() -> str:
    """Return the current UTC timestamp as an ISO-8601 string."""
    return datetime.now(timezone.utc).isoformat()


def write_json(path: Path, payload: Mapping[str, object]) -> None:
    """Write a stable JSON document."""
    path.write_text(
        json.dumps(payload, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )


def write_run_manifest(
    path: Path,
    manifest: dict[str, object],
    telemetry: GateRunTelemetry,
) -> None:
    """Write a run manifest with current e2e gate telemetry."""
    manifest["telemetry"] = telemetry.to_manifest()
    write_json(path, manifest)


def emit_e2e_budget_report(telemetry: GateRunTelemetry) -> None:
    """Write the non-failing e2e budget report to stdout."""
    sys.stdout.write(format_e2e_budget_report(telemetry.to_manifest()))


def format_e2e_budget_report(telemetry_payload: Mapping[str, object]) -> str:
    """Return a concise non-failing budget report from e2e telemetry."""
    dataflow = optional_mapping(telemetry_payload.get("dagster_dataflow"))
    target_progress = optional_mapping(
        dataflow.get("final_target_progress") if dataflow is not None else None
    )
    run_status_counts = optional_mapping(
        dataflow.get("final_run_status_counts") if dataflow is not None else None
    )
    total_duration = optional_number(
        telemetry_payload.get("total_gate_duration_seconds")
    )
    peak_active = optional_int(
        dataflow.get("peak_active_run_count") if dataflow is not None else None
    )
    peak_queued = optional_int(
        dataflow.get("peak_queued_run_count") if dataflow is not None else None
    )
    successful_runs = optional_int(
        run_status_counts.get("SUCCESS") if run_status_counts is not None else None
    )
    materialized_targets = optional_int(
        target_progress.get("materialized_target_asset_count")
        if target_progress is not None
        else None
    )
    target_count = optional_int(
        target_progress.get("target_asset_count") if target_progress is not None else None
    )
    failed_checks = optional_int(
        dataflow.get("final_failed_asset_check_count") if dataflow is not None else None
    )

    return "\n".join(
        (
            "E2E budget report (non-failing):",
            "- total gate duration: "
            f"{format_optional_duration(total_duration)} "
            f"({format_budget_baseline_comparison(total_duration)})",
            "- peak active/queued runs: "
            f"{format_peak_run_counts(peak_active, peak_queued)}",
            "- final successful runs: " f"{format_optional_count(successful_runs)}",
            "- target progress: "
            f"{format_target_progress(materialized_targets, target_count)}",
            "- final asset-check status: "
            f"{format_failed_asset_check_count(failed_checks)}",
            "",
        )
    )


def optional_mapping(value: object) -> Mapping[str, object] | None:
    """Return a mapping payload or None."""
    if isinstance(value, Mapping):
        return value
    return None


def optional_number(value: object) -> float | None:
    """Return a numeric telemetry value or None."""
    if isinstance(value, bool):
        return None
    if isinstance(value, int | float):
        return float(value)
    return None


def optional_int(value: object) -> int | None:
    """Return an integer telemetry value or None."""
    if isinstance(value, bool):
        return None
    if isinstance(value, int):
        return value
    return None


def format_optional_duration(seconds: float | None) -> str:
    """Return a duration label or unavailable marker."""
    if seconds is None:
        return "unavailable"
    return format_duration(seconds)


def format_duration(seconds: float) -> str:
    """Return a compact minute/second duration."""
    rounded = int(round(max(0.0, seconds)))
    minutes, remaining_seconds = divmod(rounded, 60)
    if minutes == 0:
        return f"{remaining_seconds}s"
    return f"{minutes}m{remaining_seconds:02d}s"


def format_budget_baseline_comparison(total_duration: float | None) -> str:
    """Return a non-failing comparison to the observed e2e baseline."""
    baseline = format_duration(E2E_BUDGET_BASELINE_SECONDS)
    if total_duration is None:
        return f"baseline {baseline}"
    delta = int(round(total_duration - E2E_BUDGET_BASELINE_SECONDS))
    if delta < 0:
        return f"{format_duration(abs(delta))} below {baseline} baseline"
    if delta > 0:
        return f"{format_duration(delta)} above {baseline} baseline"
    return f"matches {baseline} baseline"


def format_peak_run_counts(active_count: int | None, queued_count: int | None) -> str:
    """Return a peak active/queued run summary."""
    if active_count is None or queued_count is None:
        return "unavailable"
    return f"{active_count} active / {queued_count} queued"


def format_optional_count(count: int | None) -> str:
    """Return a count or unavailable marker."""
    if count is None:
        return "unavailable"
    return str(count)


def format_target_progress(
    materialized_targets: int | None,
    target_count: int | None,
) -> str:
    """Return final target materialization progress."""
    if materialized_targets is None or target_count is None:
        return "unavailable"
    return f"{materialized_targets}/{target_count} materialized"


def format_failed_asset_check_count(failed_checks: int | None) -> str:
    """Return final failed asset-check status."""
    if failed_checks is None:
        return "unavailable"
    return f"{failed_checks} failed"


def timestamp_iso_or_none(timestamp: float | None) -> str | None:
    """Return a UTC ISO-8601 timestamp for a Unix timestamp."""
    if timestamp is None:
        return None
    return datetime.fromtimestamp(timestamp, timezone.utc).isoformat()


def elapsed_seconds(started: float, completed: float) -> float:
    """Return a non-negative elapsed duration in seconds."""
    return max(0.0, completed - started)


def optional_duration_seconds(duration: float | None) -> float | None:
    """Return a rounded optional duration for JSON telemetry."""
    if duration is None:
        return None
    return round_duration_seconds(duration)


def round_duration_seconds(duration: float) -> float:
    """Round a duration for stable JSON telemetry."""
    return round(max(0.0, duration), 3)


def yaml_quote(value: str) -> str:
    """Return a double-quoted YAML scalar using JSON string escaping."""
    return json.dumps(value)


def format_called_process_error(error: subprocess.CalledProcessError) -> str:
    """Format subprocess failure details for CLI stderr."""
    lines = [
        f"error: command failed with exit code {error.returncode}: "
        f"{format_command(error.cmd)}\n"
    ]
    if error.stdout:
        lines.append(error.stdout)
        if not error.stdout.endswith("\n"):
            lines.append("\n")
    if error.stderr:
        lines.append(error.stderr)
        if not error.stderr.endswith("\n"):
            lines.append("\n")
    return "".join(lines)


def format_command(command: object) -> str:
    """Return a readable command string."""
    if isinstance(command, list | tuple):
        return " ".join(str(part) for part in command)
    return str(command)


if __name__ == "__main__":
    raise SystemExit(main())
