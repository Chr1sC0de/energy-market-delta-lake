# -----------------------------------------------------------------------
# Local development environment variables
# Consumed by compose.yaml via env_file / environment interpolation.
# DO NOT commit real credentials — this file is for local mock values only.
# -----------------------------------------------------------------------

# --- PostgreSQL superuser (used by the postgres image itself) -----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# --- Dagster application database ---------------------------------------
DAGSTER_POSTGRES_HOSTNAME=postgres
DAGSTER_POSTGRES_USER=dagster_user
DAGSTER_POSTGRES_PASSWORD=dagster_pass
DAGSTER_POSTGRES_DB=dagster

# --- AWS / S3 (mocked via LocalStack) -----------------------------------
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DEFAULT_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
