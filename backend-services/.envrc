#!/usr/bin/env bash
# -----------------------------------------------------------------------
# Local development environment variables
# Consumed by compose.yaml via env_file / environment interpolation.
# DO NOT commit real credentials — this file is for local mock values only.
# -----------------------------------------------------------------------

# --- PostgreSQL superuser (used by the postgres image itself) -----------
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=postgres
export POSTGRES_DB=postgres

# --- Dagster application database ---------------------------------------
export DAGSTER_POSTGRES_HOSTNAME=postgres
export DAGSTER_POSTGRES_USER=dagster_user
export DAGSTER_POSTGRES_PASSWORD=dagster_pass
export DAGSTER_POSTGRES_DB=dagster

# --- AWS / S3 (mocked via LocalStack) -----------------------------------
export AWS_ENDPOINT_URL=http://localstack:4566
export AWS_DEFAULT_REGION=ap-southeast-4
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test

# --- Caddy reverse proxy ------------------------------------------------
export DAGSTER_WEBSERVER_GUEST=http://dagster-webserver-guest:3000
export DAGSTER_WEBSERVER_ADMIN=http://dagster-webserver-admin:3000
export DAGSTER_AUTHSERVER=http://authentication:8000
export MARIMO_SERVER=http://marimo:2718
# ROOT_DNS must include the port when not 443, so Caddy binds on :8443 locally.
# In production set ROOT_DNS=yourdomain.com (no port) and LOCAL_CERTS= (empty).
export ROOT_DNS=https://localhost
export WEBSITE_ROOT_URL=https://localhost
# LOCAL_CERTS=local_certs enables Caddy's internal CA (self-signed) for local dev.
# In production leave this unset/empty so the global acme_ca is used instead.
export LOCAL_CERTS=local_certs
export DEVELOPER_EMAIL=local@localhost

# --- Cognito (mocked via LocalStack) ------------------------------------
# enable this when we scale enough to want to use base features from localstack
# export COGNITO_DAGSTER_USER_POOL_ID="$AWS_DEFAULT_REGION"_abcd1234
# export COGNITO_DAGSTER_AUTH_CLIENT_ID=abcd1234
# export COGNITO_DAGSTER_AUTH_CLIENT_NAME=_custom_id_:"$COGNITO_DAGSTER_AUTH_CLIENT_ID"
# export COGNITO_DAGSTER_AUTH_SERVER_METADATA_URL=https://cognito-idp."$AWS_DEFAULT_REGION".amazonaws.com/"$COGNITO_DAGSTER_USER_POOL_ID"/.well-known/openid-configuration
