---
const nodeWidth = 156;
const nodeHeight = 78;

const desktopNodes = [
  {
    className: "architecture-node-green",
    detail: "Market source inputs",
    label: "AEMO files",
    meta: "source",
    x: 84,
    y: 103,
  },
  {
    className: "architecture-node-slate",
    detail: "Orchestrated ETL",
    label: "Dagster assets",
    meta: "runtime",
    x: 288,
    y: 103,
  },
  {
    className: "architecture-node-green",
    detail: "Curated tables",
    label: "Delta lake",
    meta: "storage",
    x: 492,
    y: 103,
  },
  {
    className: "architecture-node-blue",
    detail: "Public entrypoint",
    label: "Caddy edge",
    meta: "access",
    x: 84,
    y: 279,
  },
  {
    className: "architecture-node-blue",
    detail: "Guest and admin",
    label: "Dagster UI",
    meta: "service",
    x: 288,
    y: 241,
  },
  {
    className: "architecture-node-green",
    detail: "Protected notebooks",
    label: "Marimo",
    meta: "service",
    x: 288,
    y: 355,
  },
  {
    className: "architecture-node-slate",
    detail: "Checked changes",
    label: "AI delivery system",
    meta: "automation",
    x: 492,
    y: 279,
  },
];

const mobileNodes = [
  {
    className: "architecture-node-green",
    detail: "Market source inputs",
    label: "AEMO files",
    meta: "source",
    x: 20,
    y: 20,
  },
  {
    className: "architecture-node-slate",
    detail: "Orchestrated ETL",
    label: "Dagster assets",
    meta: "runtime",
    x: 214,
    y: 20,
  },
  {
    className: "architecture-node-green",
    detail: "Curated tables",
    label: "Delta lake",
    meta: "storage",
    x: 214,
    y: 118,
  },
  {
    className: "architecture-node-blue",
    detail: "Public entrypoint",
    label: "Caddy edge",
    meta: "access",
    x: 20,
    y: 167,
  },
  {
    className: "architecture-node-blue",
    detail: "Guest and admin",
    label: "Dagster UI",
    meta: "service",
    x: 214,
    y: 216,
  },
  {
    className: "architecture-node-green",
    detail: "Protected notebooks",
    label: "Marimo",
    meta: "service",
    x: 214,
    y: 314,
  },
  {
    className: "architecture-node-slate",
    detail: "Checked changes",
    label: "AI delivery system",
    meta: "automation",
    x: 20,
    y: 314,
  },
];

const desktopEdges = ["M240 142H288", "M444 142H492", "M240 318H264V280H288", "M240 318H264V394H288", "M492 318H468V142H444"];
const mobileEdges = ["M176 59H214", "M292 98V118", "M176 206H195V255H214", "M176 206H195V353H214", "M176 353H195V59H214"];
---

<div class="architecture-flow-card architecture-flow-card-fallback" aria-label="Architecture overview">
  <div class="architecture-flow-header">
    <span>Architecture overview</span>
    <strong>Public edge to data products</strong>
    <span class="architecture-open-detail architecture-open-detail-fallback">Open detail</span>
  </div>
  <div class="architecture-flow flow-loading-canvas architecture-static-flow" aria-hidden="true">
    <div class="static-flow-stage static-architecture-stage">
      <svg class="static-architecture-svg static-architecture-svg-desktop" viewBox="0 0 732 510">
        <defs>
          <marker
            id="static-architecture-arrow-desktop"
            markerHeight="16"
            markerUnits="userSpaceOnUse"
            markerWidth="16"
            orient="auto"
            refX="14"
            refY="8"
            viewBox="0 0 16 16"
          >
            <path d="M2 2L14 8L2 14Z"></path>
          </marker>
        </defs>
        <g transform="matrix(1.2 0 0 1.2 -81 -71)">
          <g class="static-flow-edges">
            {
              desktopEdges.map((edge) => (
                <path d={edge} marker-end="url(#static-architecture-arrow-desktop)"></path>
              ))
            }
          </g>
          {
            desktopNodes.map((node) => (
              <foreignObject x={node.x} y={node.y} width={nodeWidth} height={nodeHeight} overflow="visible">
                <div xmlns="http://www.w3.org/1999/xhtml" class={`architecture-node ${node.className}`}>
                  <span>{node.meta}</span>
                  <strong>{node.label}</strong>
                  <small>{node.detail}</small>
                </div>
              </foreignObject>
            ))
          }
        </g>
      </svg>

      <svg class="static-architecture-svg static-architecture-svg-mobile" viewBox="0 0 390 412">
        <defs>
          <marker
            id="static-architecture-arrow-mobile"
            markerHeight="16"
            markerUnits="userSpaceOnUse"
            markerWidth="16"
            orient="auto"
            refX="14"
            refY="8"
            viewBox="0 0 16 16"
          >
            <path d="M2 2L14 8L2 14Z"></path>
          </marker>
        </defs>
        <g class="static-flow-edges">
          {
            mobileEdges.map((edge) => (
              <path d={edge} marker-end="url(#static-architecture-arrow-mobile)"></path>
            ))
          }
        </g>
        {
          mobileNodes.map((node) => (
            <foreignObject x={node.x} y={node.y} width={nodeWidth} height={nodeHeight} overflow="visible">
              <div xmlns="http://www.w3.org/1999/xhtml" class={`architecture-node ${node.className}`}>
                <span>{node.meta}</span>
                <strong>{node.label}</strong>
                <small>{node.detail}</small>
              </div>
            </foreignObject>
          ))
        }
      </svg>
    </div>
  </div>
  <span class="sr-only">Architecture overview</span>
</div>
