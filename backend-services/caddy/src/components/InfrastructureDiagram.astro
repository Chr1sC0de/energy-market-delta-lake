---
const stackGroups = [
  {
    id: "cloud",
    label: "Cloud and infrastructure",
    detail: "Provisioned, deployed, and wired as a reproducible cloud platform.",
    tone: "blue",
    items: [
      {
        label: "AWS",
        detail: "Deployment target across EC2, ECS, S3, DynamoDB, Route 53, SSM, and Cognito.",
        meta: "cloud",
        tone: "blue",
      },
      {
        label: "Pulumi",
        detail: "Python infrastructure as code for network, compute, storage, auth, and service wiring.",
        meta: "IaC",
        tone: "green",
      },
    ],
  },
  {
    id: "data",
    label: "Data platform",
    detail: "Assets, state, and language choices behind the energy-market pipelines.",
    tone: "green",
    items: [
      {
        label: "Dagster",
        detail: "Asset orchestration, schedules, run history, and admin or guest run surfaces.",
        meta: "orchestrate",
        tone: "blue",
      },
      {
        label: "Python",
        detail: "Core language for ETL assets, infrastructure tests, and automation tools.",
        meta: "language",
        tone: "amber",
      },
      {
        label: "PostgreSQL",
        detail: "Run, schedule, and event-log state for the Dagster services.",
        meta: "state",
        tone: "red",
      },
    ],
  },
  {
    id: "apps",
    label: "Apps and access",
    detail: "Public portfolio, protected tools, auth, and routing surfaces.",
    tone: "red",
    items: [
      {
        label: "Astro",
        detail: "Static portfolio frontend compiled into the Caddy image.",
        meta: "frontend",
        tone: "slate",
      },
      {
        label: "Marimo",
        detail: "Notebook and dashboard surface for exploring curated tables.",
        meta: "notebooks",
        tone: "green",
      },
      {
        label: "FastAPI",
        detail: "Authentication service that validates browser sessions for protected routes.",
        meta: "auth",
        tone: "amber",
      },
      {
        label: "Caddy",
        detail: "Public edge for TLS, static assets, and reverse proxy routing.",
        meta: "edge",
        tone: "blue",
      },
    ],
  },
  {
    id: "delivery",
    label: "Runtime and delivery",
    detail: "Local execution, operational glue, and Codex-supported change flow.",
    tone: "amber",
    items: [
      {
        label: "Podman",
        detail: "Local container runtime for integration services and image builds.",
        meta: "containers",
        tone: "green",
      },
      {
        label: "Bash",
        detail: "Operational scripts for checks, deployment helpers, and service setup.",
        meta: "ops",
        tone: "slate",
      },
      {
        label: "Codex",
        detail: "AI coding agent used to shape, implement, test, and review changes.",
        meta: "AI delivery",
        tone: "blue",
      },
    ],
  },
];
---

<section class="section-band tech-stack-section" id="tech-stack" aria-labelledby="tech-stack-title">
  <div class="section-inner">
    <div class="section-heading">
      <p class="eyebrow">Tech stack</p>
      <h2 id="tech-stack-title">Built across cloud, data, apps, and delivery.</h2>
      <p>
        The project combines AWS infrastructure, Dagster data orchestration, protected app surfaces, and Codex-supported delivery into one deployable portfolio.
      </p>
    </div>

    <div class="tech-stack-map" aria-label="Technology stack grouped by capability area">
      {
        stackGroups.map((group) => (
          <section class={`tech-stack-group tech-stack-group-${group.tone}`} aria-labelledby={`tech-stack-${group.id}`}>
            <div class="tech-stack-group-heading">
              <span id={`tech-stack-${group.id}`}>{group.label}</span>
              <p>{group.detail}</p>
            </div>

            <div class="tech-stack-grid">
              {
                group.items.map((item) => (
                  <article class={`tech-card tone-${item.tone}`}>
                    <div class="tech-card-top">
                      <span>{item.meta}</span>
                    </div>
                    <h3>{item.label}</h3>
                    <p>{item.detail}</p>
                  </article>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </div>
</section>
