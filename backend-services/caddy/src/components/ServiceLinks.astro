---
const services = [
  {
    href: "/dagster-webserver/guest",
    label: "Guest asset graph",
    detail: "Read-only Dagster catalogue and recent runs",
    state: "open",
    tone: "blue",
    icon: "DG",
  },
  {
    href: "/dagster-webserver/admin",
    label: "Dagster operations",
    detail: "Launchpad, materializations, and run repair",
    state: "protected",
    tone: "amber",
    icon: "DA",
  },
  {
    href: "/marimo",
    label: "Dashboard command center",
    detail: "Protected Marimo notebook chooser",
    state: "protected",
    tone: "green",
    icon: "MO",
  },
];
---

<nav class="service-links" aria-label="Primary service links">
  {
    services.map((service) => (
      <a class={`service-link service-link-${service.tone}`} href={service.href}>
        <span class="service-icon" aria-hidden="true">{service.icon}</span>
        <span class="service-copy">
          <strong>{service.label}</strong>
          <small>{service.detail}</small>
        </span>
        <span class="service-state">{service.state}</span>
      </a>
    ))
  }
</nav>
