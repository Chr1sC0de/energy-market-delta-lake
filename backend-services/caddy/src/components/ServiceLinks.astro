---
const services = [
  {
    href: "/marimo",
    label: "Dashboard atlas",
    detail: "Protected concept-led Marimo dashboard discovery",
    state: "protected",
    tone: "green",
    icon: "AT",
  },
  {
    href: "#source-coverage",
    label: "Source coverage",
    detail: "GBB, STTM, DWGM, VICGAS, and curated assets",
    state: "overview",
    tone: "blue",
    icon: "SC",
  },
  {
    href: "/dagster-webserver/guest",
    label: "Asset graph",
    detail: "Public Dagster guest view for pipeline context",
    state: "public",
    tone: "amber",
    icon: "AG",
  },
];
---

<nav class="service-links" aria-label="Primary atlas links">
  {
    services.map((service) => (
      <a class={`service-link service-link-${service.tone}`} href={service.href}>
        <span class="service-icon" aria-hidden="true">{service.icon}</span>
        <span class="service-copy">
          <strong>{service.label}</strong>
          <small>{service.detail}</small>
        </span>
        <span class="service-state">{service.state}</span>
      </a>
    ))
  }
</nav>
