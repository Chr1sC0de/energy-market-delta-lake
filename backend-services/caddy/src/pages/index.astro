---
import AutomationWorkflowFlow from "../components/AutomationWorkflowFlow";
import InfrastructureDiagram from "../components/InfrastructureDiagram.astro";
import ServiceLinks from "../components/ServiceLinks.astro";
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
---

<PortfolioLayout
  title="Energy Market Delta Lake"
  description="Energy Market Delta Lake portfolio entrypoint for Australian energy market ingestion, orchestration, storage, protected notebooks, and an AI delivery system."
>
  <main>
    <section class="hero command-hero" aria-labelledby="page-title">
      <div class="hero-inner">
        <div class="hero-heading">
          <p class="eyebrow">Operator command center</p>
          <h1 id="page-title">Energy Market Delta Lake</h1>
        </div>
        <div class="hero-copy">
          <p class="hero-lede">
            One entrypoint for platform readiness, protected service access, and the fastest route into operational gas-market dashboards.
          </p>
          <ServiceLinks />
        </div>
        <div class="command-panel" aria-label="Platform readiness overview">
          <div class="command-panel-header">
            <span>Platform readiness</span>
            <strong>Local and deployed operator surfaces</strong>
          </div>
          <div class="readiness-grid" aria-label="Service readiness">
            <div class="readiness-card tone-green">
              <span>Dashboards</span>
              <strong>Registry-backed</strong>
              <small>Available and planned Marimo entries from runtime metadata</small>
            </div>
            <div class="readiness-card tone-blue">
              <span>Storage</span>
              <strong>S3-compatible Delta</strong>
              <small>Bronze, silver, and gold gas-market paths stay inspectable</small>
            </div>
            <div class="readiness-card tone-amber">
              <span>Orchestration</span>
              <strong>Dagster protected</strong>
              <small>Admin operations remain behind browser auth</small>
            </div>
            <div class="readiness-card tone-slate">
              <span>Delivery</span>
              <strong>Ralph evidence loop</strong>
              <small>Test lane and Review package evidence before handoff</small>
            </div>
          </div>
          <div class="priority-actions" aria-label="Priority operator actions">
            <a class="primary-action" href="/marimo">Choose a dashboard</a>
            <a class="secondary-action" href="/dagster-webserver/admin">Open protected Dagster</a>
            <a class="secondary-action" href="/dagster-webserver/guest">Inspect public graph</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-band route-map-section" aria-labelledby="route-map-title">
      <div class="section-inner">
        <div class="section-heading section-heading-split">
          <div>
            <p class="eyebrow">Route model</p>
            <h2 id="route-map-title">Caddy leads entry. Marimo owns notebooks.</h2>
          </div>
          <p>
            The static command center gives operators a stable first choice while Marimo keeps the live registry JSON and notebook applications.
          </p>
        </div>
        <div class="route-map-grid">
          <div class="route-card tone-green">
            <span>/marimo</span>
            <strong>Caddy-served dashboard listing</strong>
            <p>Protected exact route built by Astro, sharing the homepage command-center visual system.</p>
          </div>
          <div class="route-card tone-blue">
            <span>/marimo/dashboard-registry.json</span>
            <strong>Marimo-owned registry</strong>
            <p>Runtime dependency fetched by the listing so available and planned entries reflect the image.</p>
          </div>
          <div class="route-card tone-amber">
            <span>/marimo/&lt;notebook&gt;/</span>
            <strong>Marimo-owned notebooks</strong>
            <p>Available cards link to mounted notebook routes and keep package assets proxied by Caddy.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-band ai-workflow-section" id="ai-workflow" aria-labelledby="ai-workflow-title">
      <div class="section-inner">
        <div class="ai-workflow-layout">
          <div class="section-heading ai-workflow-heading">
            <p class="eyebrow">AI-driven delivery</p>
            <h2 id="ai-workflow-title">Ralph is the AI delivery loop.</h2>
          </div>

          <div class="ai-workflow-copy">
            <p>
              A human owns the goal and approval decision. Ralph reads the issue, makes the change, runs the checks, and gets the work ready to review.
            </p>
            <p class="ai-workflow-source">
              Huntley's framing is the idea here: give Ralph clear specs and a goal, then let the loop work while failures feed the next fix.
              <a href="https://ghuntley.com/loop/" target="_blank" rel="noreferrer">Source</a>
            </p>
          </div>

          <div class="ai-workflow-diagram">
            <AutomationWorkflowFlow client:load />
          </div>
        </div>
      </div>
    </section>

    <InfrastructureDiagram />
  </main>
</PortfolioLayout>
