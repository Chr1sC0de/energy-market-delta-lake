---
import AutomationWorkflowFlow from "../components/AutomationWorkflowFlow";
import HeroArchitectureFlow from "../components/HeroArchitectureFlow";
import HeroArchitectureFallback from "../components/HeroArchitectureFallback.astro";
import InfrastructureDiagram from "../components/InfrastructureDiagram.astro";
import ServiceLinks from "../components/ServiceLinks.astro";
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
---

<PortfolioLayout
  title="Energy Market Delta Lake"
  description="Energy Market Delta Lake portfolio entrypoint for Australian energy market ingestion, orchestration, storage, protected notebooks, and an AI delivery system."
>
  <main>
    <section class="hero" aria-labelledby="page-title">
      <div class="hero-inner">
        <div class="hero-heading">
          <p class="eyebrow">Analyst catalogue entrypoint</p>
          <h1 id="page-title">Energy Market Delta Lake</h1>
        </div>
        <div class="hero-copy">
          <p class="hero-lede">
            A deployable Australian energy-market data platform for scanning curated gas dashboards, launching protected Marimo notebooks, and tracing results back to Dagster assets and Delta storage.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="primary-action" href="/marimo">Open dashboard catalogue</a>
            <a class="secondary-action" href="/dagster-webserver/guest">View asset graph</a>
          </div>
          <ServiceLinks />
        </div>
        <div class="hero-diagram">
          <HeroArchitectureFallback />
          <div class="hero-diagram-interaction" aria-hidden="false">
            <HeroArchitectureFlow client:only="react" />
          </div>
        </div>
      </div>
    </section>

    <section class="catalogue-direction-section" aria-labelledby="catalogue-direction-title">
      <div class="section-inner catalogue-direction-inner">
        <div class="section-heading catalogue-direction-heading">
          <p class="eyebrow">Catalogue workflow</p>
          <h2 id="catalogue-direction-title">Find the right dashboard before opening a notebook.</h2>
          <p>
            The protected catalogue is designed for dense scan paths: search by
            topic, filter by audience or lifecycle status, check backing
            silver.gas_model assets, then launch available notebooks directly.
          </p>
        </div>
        <div class="catalogue-preview" aria-label="Dashboard catalogue preview">
          <div class="catalogue-preview-toolbar">
            <span>Search: capacity</span>
            <span>Audience: Analyst</span>
            <span>Status: Available</span>
          </div>
          <div class="catalogue-preview-row">
            <strong>Gas Market Overview</strong>
            <span>Available</span>
            <small>prices, schedules, flow, capacity</small>
            <a href="/marimo">Open</a>
          </div>
          <div class="catalogue-preview-row">
            <strong>Capacity Outlook Explorer</strong>
            <span>Planned</span>
            <small>silver.gas_model capacity assets</small>
            <em>Roadmap</em>
          </div>
          <div class="catalogue-preview-row">
            <strong>Source Coverage Matrix</strong>
            <span>Available</span>
            <small>source-system and source-table coverage</small>
            <a href="/marimo">Open</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section-band ai-workflow-section" id="ai-workflow" aria-labelledby="ai-workflow-title">
      <div class="section-inner">
        <div class="ai-workflow-layout">
          <div class="section-heading ai-workflow-heading">
            <p class="eyebrow">AI-driven delivery</p>
            <h2 id="ai-workflow-title">Ralph is the AI delivery loop.</h2>
          </div>

          <div class="ai-workflow-copy">
            <p>
              A human owns the goal and approval decision. Ralph reads the issue, makes the change, runs the checks, and gets the work ready to review.
            </p>
            <p class="ai-workflow-source">
              Huntley's framing is the idea here: give Ralph clear specs and a goal, then let the loop work while failures feed the next fix.
              <a href="https://ghuntley.com/loop/" target="_blank" rel="noreferrer">Source</a>
            </p>
          </div>

          <div class="ai-workflow-diagram">
            <AutomationWorkflowFlow client:load />
          </div>
        </div>
      </div>
    </section>

    <InfrastructureDiagram />
  </main>
</PortfolioLayout>
