---
import AutomationWorkflowFlow from "../components/AutomationWorkflowFlow";
import HeroArchitectureFlow from "../components/HeroArchitectureFlow";
import HeroArchitectureFallback from "../components/HeroArchitectureFallback.astro";
import InfrastructureDiagram from "../components/InfrastructureDiagram.astro";
import ServiceLinks from "../components/ServiceLinks.astro";
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
---

<PortfolioLayout
  title="Energy Market Delta Lake"
  description="Energy Market Delta Lake portfolio entrypoint for Australian energy market ingestion, orchestration, storage, protected notebooks, and an AI delivery system."
>
  <main>
    <section class="hero" aria-labelledby="page-title">
      <div class="hero-inner">
        <div class="hero-heading">
          <p class="eyebrow">Public project portfolio case study</p>
          <h1 id="page-title">Energy Market Delta Lake</h1>
        </div>
        <div class="hero-copy">
          <p class="hero-lede">
            A deployable Australian energy-market data platform with Dagster assets, S3-compatible Delta storage, protected Marimo notebooks, and an AI delivery system for checked code changes.
          </p>
          <ServiceLinks />
        </div>
        <div class="hero-diagram">
          <HeroArchitectureFallback />
          <div class="hero-diagram-interaction" aria-hidden="false">
            <HeroArchitectureFlow client:only="react" />
          </div>
        </div>
      </div>
    </section>

    <section class="section-band portfolio-story-section" aria-labelledby="portfolio-story-title">
      <div class="section-inner">
        <div class="section-heading section-heading-split">
          <div>
            <p class="eyebrow">Case study shape</p>
            <h2 id="portfolio-story-title">A deployed data-platform story, not a mock dashboard.</h2>
          </div>
          <p>
            The public entrypoint explains what the system proves before a reviewer signs in: market data becomes durable lakehouse tables, orchestration exposes the work, and protected notebooks turn coverage into reviewable evidence.
          </p>
        </div>

        <div class="story-grid" aria-label="Portfolio story checkpoints">
          <article class="story-card story-card-blue">
            <span>01</span>
            <h3>Market source coverage</h3>
            <p>
              Gas Bulletin Board and STTM concepts are represented as traceable source tables, generated Market context, and dashboard concepts.
            </p>
          </article>
          <article class="story-card story-card-green">
            <span>02</span>
            <h3>Dagster to Delta workflow</h3>
            <p>
              Assets materialize through Dagster into S3-compatible Delta storage, giving the platform a repeatable ingestion and validation path.
            </p>
          </article>
          <article class="story-card story-card-amber">
            <span>03</span>
            <h3>Protected operational evidence</h3>
            <p>
              The Marimo listing stays behind auth and presents notebooks by coverage, audience, and backing assets without exposing operator surfaces publicly.
            </p>
            <a href="/marimo">Open protected dashboard listing</a>
          </article>
          <article class="story-card story-card-slate">
            <span>04</span>
            <h3>AI delivery loop</h3>
            <p>
              Ralph turns GitHub Issues into checked changes with Test lane evidence, doc sync, and human approval before integration decisions.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section-band ai-workflow-section" id="ai-workflow" aria-labelledby="ai-workflow-title">
      <div class="section-inner">
        <div class="ai-workflow-layout">
          <div class="section-heading ai-workflow-heading">
            <p class="eyebrow">AI-driven delivery</p>
            <h2 id="ai-workflow-title">Ralph is the AI delivery loop.</h2>
          </div>

          <div class="ai-workflow-copy">
            <p>
              A human owns the goal and approval decision. Ralph reads the issue, makes the change, runs the checks, and gets the work ready to review.
            </p>
            <p class="ai-workflow-source">
              Huntley's framing is the idea here: give Ralph clear specs and a goal, then let the loop work while failures feed the next fix.
              <a href="https://ghuntley.com/loop/" target="_blank" rel="noreferrer">Source</a>
            </p>
          </div>

          <div class="ai-workflow-diagram">
            <AutomationWorkflowFlow client:load />
          </div>
        </div>
      </div>
    </section>

    <InfrastructureDiagram />
  </main>
</PortfolioLayout>
