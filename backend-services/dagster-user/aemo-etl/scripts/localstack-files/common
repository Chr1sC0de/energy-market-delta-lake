#!/usr/bin/env -S bash -euo pipefail

LOCALSTACK_PORT=4566
LOCALSTACK_HOST=localhost
NAME_PREFIX="${NAME_PREFIX:-energy-market}"
DEVELOPMENT_ENVIRONMENT="${DEVELOPMENT_ENVIRONMENT:-dev}"

export AWS_ENDPOINT_URL=http://$LOCALSTACK_HOST:$LOCALSTACK_PORT
export AWS_DEFAULT_REGION=ap-southeast-2
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_SECURITY_TOKEN=test
export AWS_SESSION_TOKEN=test

export LANDING_BUCKET="${DEVELOPMENT_ENVIRONMENT}-${NAME_PREFIX}-landing"
export ARCHIVE_BUCKET="${DEVELOPMENT_ENVIRONMENT}-${NAME_PREFIX}-archive"

: "${LOCALSTACK_LANDING_DOWNLOAD:=$HOME/localstack-landing-download}"
: "${LOCALSTACK_ARCHIVE_DOWNLOAD:=$HOME/localstack-archive-download}"

export LOCALSTACK_LANDING_DOWNLOAD
export LOCALSTACK_ARCHIVE_DOWNLOAD
