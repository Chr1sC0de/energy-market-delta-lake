{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Dagster",
      "type": "debugpy",
      "request": "attach",
      "justMyCode": true,
      "subProcess": false,
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "."
        }
      ]
    }
  ]
}
